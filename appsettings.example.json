{
  "$schema": "appsettings-schema.json",
  "CustomDomain": "https://example.com",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "http://*:80"
      }
    }
  },
  "CaptureRedirect": {
    "Enabled": false,
    "AllowedOrigins": "",
    "Paths": "/meshulam-response;/meshulam-dd-success;/meshulam-dd-failure"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "GoogleAnalytics": {
    "MeasurementID": ""
  },
  "BlobStorage": {
    "ConnectionString": ""
  },
  "AWS": {
    "Region": "",
    "AccessKey": "",
    "SecretKey": "",
    "RootUrl": "",
    "SenderEmail": ""
  },
  "Meshulam": {
    "ForceSandboxMode": false,
    "Address": "",
    "SandboxAddress": "https://sandbox.meshulam.co.il/api/light/server/1.0/",
    "UserID": "",
    "YearlyPageCode": "",
    "MonthlyPageCode": "",
    "SandboxUserID": "",
    "SandboxYearlyPageCode": "",
    "SandboxMonthlyPageCode": ""
  },
  "PaymentsHarness": {
    "Enabled": false,
    "Token": ""
  },
  "googleReCaptcha": {
    "SiteKey": "",
    "SecretKey": "",
    "MinimumScore": "0.1",
    "OnRegister": "on",
    "OnLogin": "on",
    "OnComment": "on"
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
  },
  "Umbraco": {
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ConnectionString": "",
          "ContainerName": ""
        }
      }
    },
    "CMS": {
      "Global": {
        "Id": "eabf231e-b0eb-4ca1-93c0-26b928aa53c0",
        "SanitizeTinyMce": true,
        "MainDomLock": "FileSystemMainDomLock"
      },
      "Hosting": {
        "LocalTempStorageLocation": "EnvironmentTemp"
      },
      "RuntimeMinification": {
        "UseInMemoryCache": false,
        "CacheBuster": "Version",
        "Version": "20260602-1"
      },
      "Examine": {
        "LuceneDirectoryFactory": "SyncedTempFileSystemDirectoryFactory"
      },
      "Security": {
        "UsernameIsEmail": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        },
        "Error404Collection": [
          {
            "Culture": "default",
            "ContentKey": "d32d3ab3-fc9d-487a-bfe5-99091a177512"
          }
        ]
      }
    }
  }
}
