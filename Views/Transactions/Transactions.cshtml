@model MyProject12.ViewModels.PaginatedTransactionsResult

<div id="pagination-data"
     data-total-pages="@Model.TotalPages"
     data-total-items="@Model.TotalItems"
     data-current-page="@Model.CurrentPage"
     style="display:none;"></div>

<div class="table-wrap">
    <table class="memberships-table" dir="rtl" aria-label="טבלת עסקאות">
        <thead>
            <tr>
                <th class="sortable-header" data-sortby="Created" tabindex="0" role="button" aria-label="מיון לפי תאריך יצירה">תאריך יצירה</th>
                <th class="sortable-header" data-sortby="Status" tabindex="0" role="button" aria-label="מיון לפי סטטוס">סטטוס</th>
                <th class="sortable-header" data-sortby="Sum" tabindex="0" role="button" aria-label="מיון לפי סכום">סכום</th>
                <th class="sortable-header" data-sortby="FullName" tabindex="0" role="button" aria-label="מיון לפי שם מלא">שם מלא</th>
                <th>טלפון</th>
                <th class="sortable-header" data-sortby="Email" tabindex="0" role="button" aria-label="מיון לפי אימייל">אימייל</th>
                <th>אסמכתא</th>
                <th>TransactionId</th>
                <th>TransactionToken</th>
                <th>ProcessId</th>
                <th>DirectDebitId</th>
                <th>פעולות</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Transactions == null || !Model.Transactions.Any())
            {
                <tr>
                    <td colspan="12" class="empty-row">לא נמצאו עסקאות לפי הסינון שבחרת.</td>
                </tr>
            }
            else
            {
                foreach (var transaction in Model.Transactions)
                {
                    var isSuccess = transaction.Status == "שולם";
                    var isRefunded = transaction.Status == "בוטל/זוכה";
                    var statusClass = isSuccess ? "tx-success" : (isRefunded ? "tx-refunded" : "tx-failed");
                    var canRefund = isSuccess && transaction.TransactionToken != "הוראת קבע";

                    <tr>
                        <td>@transaction.Created.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <span class="status-badge tx-status @statusClass">@transaction.Status</span>
                        </td>
                        <td>@transaction.Sum</td>
                        <td>@transaction.FullName</td>
                        <td>@transaction.PayerPhone</td>
                        <td>@transaction.PayerEmail</td>
                        <td>@transaction.Asmachta</td>
                        <td>@transaction.TransactionId</td>
                        <td class="admin-token-cell">@transaction.TransactionToken</td>
                        <td>@transaction.ProcessId</td>
                        <td>@transaction.DirectDebitId</td>
                        <td>
                            @if (canRefund)
                            {
                                <button type="button" class="btn-inline btn-danger refund-btn" data-id="@transaction.ID">ביטול/זיכוי</button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
