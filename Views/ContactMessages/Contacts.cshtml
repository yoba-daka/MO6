@model MyProject12.ViewModels.PaginatedContactResult

<div id="pagination-data"
     data-total-pages="@Model.TotalPages"
     data-total-items="@Model.TotalItems"
     data-current-page="@Model.CurrentPage"
     style="display:none;"></div>

<div class="table-wrap">
    <table class="memberships-table" dir="rtl" aria-label="טבלת פניות צור קשר">
        <thead>
            <tr>
                <th class="sortable-header" data-sortby="SubmitTime" tabindex="0" role="button" aria-label="מיון לפי תאריך">תאריך</th>
                <th class="sortable-header" data-sortby="Name" tabindex="0" role="button" aria-label="מיון לפי שם">שם</th>
                <th class="sortable-header" data-sortby="Email" tabindex="0" role="button" aria-label="מיון לפי אימייל">אימייל</th>
                <th class="sortable-header" data-sortby="Phone" tabindex="0" role="button" aria-label="מיון לפי טלפון">טלפון</th>
                <th>תוכן</th>
                <th>פעולות</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Contacts == null || !Model.Contacts.Any())
            {
                <tr>
                    <td colspan="6" class="empty-row">לא נמצאו הודעות לפי הסינון שבחרת.</td>
                </tr>
            }
            else
            {
                foreach (var contact in Model.Contacts)
                {
                    <tr>
                        <td>@contact.submitTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@($"{contact.name} {contact.familyName}".Trim())</td>
                        <td>@contact.email</td>
                        <td>@contact.phone</td>
                        <td class="admin-message-cell">@contact.content</td>
                        <td>
                            <button type="button" class="btn-inline btn-danger delete-btn" data-id="@contact.ID">מחיקה</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
