@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Event>
@{
    Layout = "master.cshtml";
    dynamic parent = Model.Parent;
}

<div class="sec-page-header page-header header-filter clear-filter" style="margin-top:0em;background-image: url('@Url.GetOptimizedCropUrl(((Events)parent).Image, "full")');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="text-center">
                    <h1>@Model.Title</h1>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="container my-5">
    <div class="my-5">

        <a class="title text-primary" href="@Model.Parent.Url()">@Model.Parent.Name</a> &nbsp>&nbsp <a class="title text-primary" href="@Model.Url()">@Model.Name</a>
    </div>

    <div class="row article p-md-3">
        <div class="col-lg-12 p-md-5 p-4 mt-md-0 mt-4 text-justify">
            <h3 class="text-center mt-0"><strong>@Model.Title</strong></h3>

            @*<h4 class=" mt-3">@Model.ShortDescription</h4>*@
            <div class="mt-5">
            @Model.FullDescription
            </div>
        </div>
    </div>
</div>

@Html.Partial("~/Views/Partials/Share.cshtml", Model)
<!--Html.Partial("~/Views/Partials/Comments.cshtml")-->
