@using MyProject12.Services
@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.About>
@{
    Layout = "master.cshtml";
}

<div class="sec-page-header page-header header-filter clear-filter" style="margin-top:0em;background-image: url('@Url.GetCropUrl(Model.Image, "full")');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="text-center">
                    <h1>אודות</h1>
                </div>
            </div>
        </div>
    </div>
</div>

<nav id="cd-vertical-nav">
    <ul class="mb-0 p-3">
        <li>
            <a href="#1" data-number="1">
                <span class="cd-dot"></span>
                <span class="text-primary cd-label">אודות</span>
            </a>
        </li>
        <li>
            <a href="#2" data-number="2">
                <span class="cd-dot"></span>
                <span class="text-primary cd-label">מכתבי תודה</span>
            </a>
        </li>
        <li>
            <a href="#3" data-number="3">
                <span class="cd-dot"></span>
                <span class="text-primary cd-label">מהתקשורת</span>
            </a>
        </li>
        <li>
            <a href="#4" data-number="4">
                <span class="cd-dot"></span>
                <span class="text-primary cd-label">לקוחות</span>
            </a>
        </li>

    </ul>
</nav>

<div class="container">

    <div class="sec" id="1"></div>
    <h2 class="title text-primary">משה שרון</h2>


    <div class="row article p-md-3 mt-md-0 mt-4">
        <div class="col-lg-12 p-md-5 p-4 text-justify">

    @Model.Content

        </div>
    </div>

    <hr class="mt-4" />

    <div class="sec" id="2"></div>
    <h2 class="title text-primary">מכתבי תודה</h2>
    <div class="row  pl-3">
        @foreach (Recommendation r in Model.RecommendationList)
        {

            <div class="col-lg-3 col-md-4 col-6 pl-0 " style="overflow:hidden">
                <a href="@r.Url()">
                    <img src="@Url.GetCropUrl(r.Image, "small")" alt="@r.ImageAlt" class="rounded img-fluid">
                    <h5 style="line-height: 22px;" class="title m-2" class="title m-2">@r.Title</h5>
                </a>
            </div>
        }
    </div>
    <hr />


    <div class="sec" id="3"></div>
    <h2 class="title text-primary">מן התקשורת</h2>
    <div class="row  pl-3">
        @foreach (FromMedia fm in Model.FromMediaList)
        {

            <div class="col-lg-3 col-md-4 col-6 pl-0 " style="overflow:hidden">
                <a target="_blank" href="@fm.Content">
                    <img src="@Url.GetCropUrl(fm.Image, "small")" alt="@fm.ImageAlt" class="rounded img-fluid">
                    <h5 style="line-height: 22px;" class="title m-2" class="title m-2">@fm.Title</h5>
                </a>
            </div>

        }
        </div>
        <hr />


        <div class="sec" id="4"></div>
        <h2 class="title text-primary">לקוחות</h2>
        <div class="row">
            @foreach (Customer c in Model.CustomerList)
            {
                <div class="col-lg-2 col-md-3 col-4">
                    <div class="my-3 rounded customer-frame" style="background-color:white;">
                    <a target="_blank" href="@c.Link">
                            <img src="@c.Image.Src" alt="@c.ImageAlt" class="customer-image p-3 rounded img-fluid">
                        </a>
                    </div>
                </div>
            }
        </div>
        <hr />
    </div>


    <script src="/js/vertical-nav.js"></script>
