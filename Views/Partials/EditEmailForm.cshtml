@using MyProject12.Controllers;
@using MyProject12.ViewModels;
@model EmailChangeViewModel



<div class="modal fade" id="changeEmailModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            @if (TempData.ContainsKey("SuccessMessageEmail"))
            {
                <div class="col-sm-12 text-center">
                    <h2 class="text-success text-center m-2">@TempData["SuccessMessageEmail"]</h2>
                </div>
            }
            else
            {
                @using (Html.BeginUmbracoForm<AccountController>("HandleEmailChange"))
                {
                    <div class="modal-header">
                        <div class="col-sm-12 text-center">
                            <button type="button" class="close" data-dismiss="modal" aria-label="סגור"><i class="material-icons" aria-hidden="true" lang="en" translate="no">clear</i></button>
                            <h4 class="modal-title text-primary">שינוי אימייל</h4>
                            <p class="mt-2">לאחר השינוי ישלח אימייל לכתובת החדשה לאימות האימייל החדש.</p>
                            <p>אם לחשבון הוראת קבע, כתובת האימייל תעודכן גם בה.</p>

                        </div>
                    </div>
                    <div class="modal-body mx-4">
                        <div class="form-group  bmd-form-group">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons" aria-hidden="true" lang="en" translate="no">email</i>
                                    </span>
                                </div>
                                <label asp-for="Email" class="bmd-label-floating login-field">אימייל חדש</label>
                                <input asp-for="Email" type="email" autocomplete="email" class="form-control" aria-describedby="EmailChange_Email-error" aria-invalid="false" />
                                <span asp-validation-for="Email" id="EmailChange_Email-error" class="login-error" role="alert" aria-live="polite"></span>
                            </div>
                        </div>
                        <div class="form-group  bmd-form-group">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons" aria-hidden="true" lang="en" translate="no">email</i>
                                    </span>
                                </div>
                                <label asp-for="ConfirmEmail" class="bmd-label-floating login-field">אימות אימייל</label>
                                <input asp-for="ConfirmEmail" type="email" autocomplete="email" class="form-control" aria-describedby="EmailChange_ConfirmEmail-error" aria-invalid="false" />
                                <span asp-validation-for="ConfirmEmail" id="EmailChange_ConfirmEmail-error" class="login-error" role="alert" aria-live="polite"></span>
                            </div>
                        </div>
                        <div class="form-group   bmd-form-group">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons" aria-hidden="true" lang="en" translate="no">password</i>
                                    </span>
                                </div>
                                <label asp-for="CurrentPassword" class="bmd-label-floating login-field">סיסמא</label>
                                <input asp-for="CurrentPassword" type="password" autocomplete="current-password" class="form-control" aria-describedby="EmailChange_CurrentPassword-error" aria-invalid="false" />
                                <span asp-validation-for="CurrentPassword" id="EmailChange_CurrentPassword-error" class="login-error" role="alert" aria-live="polite"></span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        @if (ViewData.ModelState.ContainsKey("EmailChange"))
                        {
                            <div class="form-group bmd-form-group">
                                <div style="text-align:center">
                                    @foreach (var error in ViewData.ModelState["EmailChange"].Errors)
                                    {
                                        <div class="text-danger mb-2">@error.ErrorMessage </div>
                                    }
                                </div>
                            </div>
                        }
                        <button type="submit" class="btn btn-primary btn-link btn-wd btn-lg">עדכון</button>
                    </div>
                }
            }
        </div>
    </div>
</div>
