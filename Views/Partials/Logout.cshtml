@using MyProject12.Controllers;
@using Umbraco.Cms.Web.Website.Controllers;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
<div class="modal fade bd-example-modal-sm" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="סגור"><i class="material-icons" aria-hidden="true" lang="en" translate="no">clear</i></button>
            </div>
            <div class="modal-body text-center">
                <h5>להתנתק מהחשבון?</h5>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-link" data-dismiss="modal">ביטול</button>
                @using (Html.BeginUmbracoForm<CustomLoginStatusController>("HandleLogout"))
                {
                    <button type="submit" class="btn btn-danger btn-link">התנתקות</button>
                }
            </div>
        </div>
    </div>
</div>
<script>
    document.getElementById('logoutModal')?.addEventListener('submit', function (event) {
        const form = event.target;
        if (!form || form.dataset.offlineMembershipCleared === 'true') return;
        if (typeof offlineContentDB === 'undefined' || !offlineContentDB.clearMembershipStatus) return;

        event.preventDefault();
        form.dataset.offlineMembershipCleared = 'true';
        offlineContentDB.clearMembershipStatus()
            .catch(error => console.warn('[Logout] Failed to clear offline membership status.', error))
            .finally(() => HTMLFormElement.prototype.submit.call(form));
    });
</script>
