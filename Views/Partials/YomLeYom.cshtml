                    <div class="text-center">
                        <h4 class="px-5 pb-4 ">
                        <strong>    @ylys[2]</strong>
                        </h4>
                    </div>


                @*      <div class="col-md-3">
                <div class="customer-image  text-center">
                <div class="text-center">
                <h4 class="px-5 pt-4">
                מתוך הספר
