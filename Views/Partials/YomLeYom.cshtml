@using Microsoft.Extensions.Caching.Memory;
@using System.Net;
@using Umbraco.Cms.Core.Security;
@using Umbraco.Cms.Web.Common.PublishedModels;
@using Microsoft.AspNetCore.Hosting
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using System.Globalization;
@inject IMemoryCache Cache
@inject IWebHostEnvironment Env
@{

    string cacheItemKey = "yomleyom";
    string ex = "";
    string[] ylys = new string[] { };
    if (!Cache.TryGetValue(cacheItemKey, out string yomleyom))
    {
        try
        {
            int counter = 0;

            string[] yl = System.IO.File.ReadAllText(Env.ContentRootPath + @"/PrivateFiles/yomleyom.txt").Split('@');
            string[,] array = new string[12, 30];
            for (int i = 0; i < 12; i++)
            {
                for (int j = 0; j < 30; j++)
                {
                    if ((i == 3 || i == 5 || i == 7 || i == 9 || i == 11) && j == 29) { break; }
                    array[i, j] = yl[counter];
                    counter++;
                }
            }
            array[5, 29] = "וְהִנֵּה בֶּאֱמֶת, בִּשְׁעַת בִּיטּוּל שֶׁנִּתְבַּטֵּל אֶל הַתַּכְלִית שֶׁהוּא כֻּלּוֹ טוֹב כֻּלּוֹ אֶחָד אֲזַי בֶּאֱמֶת נִתְבַּטְּלִין הַיִּסּוּרִים כַּנַּ\"ל אַך אִי אֶפְשָׁר לִהְיוֹת תָּמִיד קָבוּעַ בִּבְחִינוֹת הַבִּיטּוּל כִּי אִם כֵּן יֵצֵא מִגֶּדֶר אֱנוֹשִׁי וְעַל כֵּן מֻכְרָח שֶׁיִּהְיֶה הַבִּיטּוּל בִּבְחִינוֹת רָצוֹא וָשׁוֹב#\n" +
                    "רבי נחמן מברסלב | ליקוטי מוהר\"ן ס\"ה";


            DateTime today = DateTime.Now;
            Calendar HebCal = new HebrewCalendar();
            CultureInfo culture = CultureInfo.CreateSpecificCulture("he-IL");
            culture.DateTimeFormat.Calendar = HebCal;

            var xg = HebCal.GetMonth(today);
            xg = (HebCal.IsLeapYear(HebCal.GetYear(today)) && (xg > 6)) ? xg - 1 : xg;
            int D = HebCal.GetDayOfMonth(today);
            yomleyom = today.ToString("d MMMM yyyyy", culture) + "#" + array[xg - 1, HebCal.GetDayOfMonth(today) - 1];

            ylys = yomleyom.Split('#');

        }
        catch (Exception e)
        {
            yomleyom = "####";

            Console.WriteLine(e.Message);
            Console.WriteLine(e.InnerException?.Message);

        }
        var cacheEntryOptions = new MemoryCacheEntryOptions
                {
                    AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(60)
                };
        Cache.Set(cacheItemKey, yomleyom, cacheEntryOptions);
    }

    else ylys = yomleyom.Split('#');


}

