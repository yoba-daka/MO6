                  <i class="mdi mdi-monitor-cellphone" style="font-size:1.1rem;line-height:1;" aria-hidden="true"></i>
                  האפליקציה שלנו
                </button>
                        <small class="d-block mt-2">
          התקינו את האפליקציה כדי להוריד שיעורים.
        </small>`;

              // Correct binding (was pointing at a non-existent #install-pwa-btn)
              const btn = document.getElementById('our-app');
