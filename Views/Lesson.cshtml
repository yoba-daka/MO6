        function getActiveMediaType() {
            return $('#videoB').hasClass('active') ? 'video' : 'audio';
        }

        function postServiceWorkerMessage(message) {
            const controller = navigator.serviceWorker?.controller;
            if (!controller) {
                console.warn('[PWA] Service Worker controller is not available.');
                return false;
            }

            controller.postMessage(message);
            return true;
        }

        function toAbsoluteUrl(url, baseUrl) {
            return new URL(url, baseUrl || window.location.href).href;
        }

        function collectPlaylistUrls(playlistText, playlistUrl) {
            const urls = [];
            const uriAttributePattern = /\bURI="([^"]+)"/gi;
            const addUrl = (value) => {
                if (!value || value.startsWith('data:')) return;
                try {
                    const absoluteUrl = new URL(value, playlistUrl);
                    if (absoluteUrl.protocol !== 'http:' && absoluteUrl.protocol !== 'https:') return;
                    urls.push(absoluteUrl.href);
                } catch {
                }
            };

            playlistText.split('\n').forEach(rawLine => {
                const line = rawLine.trim();
                if (!line) return;

                if (line.startsWith('#')) {
                    uriAttributePattern.lastIndex = 0;
                    let match;
                    while ((match = uriAttributePattern.exec(line)) !== null) {
                        addUrl(match[1]);
                    }
                    return;
                }

                addUrl(line);
            });

            return urls;
        }

        function uniqueUrls(urls) {
            return [...new Set(urls.filter(Boolean))];
        }

        async function getPlaylistText(url) {
            const response = await fetch(url, { credentials: 'same-origin' });
            if (!response.ok) {
                throw new Error(`Playlist request failed: ${response.status}`);
            }

            return response.text();
        }

        function resolveQualityPlaylistUrl(masterContent, masterUrl, resolution) {
            const playlistFile = `${resolution.replace('p', '')}p.m3u8`;
            const playlistFileLower = `/${playlistFile.toLowerCase()}`;
            const playlistUrls = collectPlaylistUrls(masterContent, masterUrl);
            return playlistUrls.find(url => new URL(url).pathname.toLowerCase().endsWith(playlistFileLower))
                || toAbsoluteUrl(playlistFile, masterUrl);
        }

        async function buildHlsDownloadUrls(resolution) {
            const masterUrl = toAbsoluteUrl(lessonConfig.hlsMasterPlaylistUrl);
            const masterContent = await getPlaylistText(masterUrl);
            const playlistUrl = resolveQualityPlaylistUrl(masterContent, masterUrl, resolution);
            const playlistContent = await getPlaylistText(playlistUrl);
            const mediaUrls = collectPlaylistUrls(playlistContent, playlistUrl);

            return {
                playlistUrl,
                urls: uniqueUrls([masterUrl, playlistUrl, ...mediaUrls])
            };
        }

