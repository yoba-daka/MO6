        async function handleDeleteClick(mediaType) {
            if (confirm(`האם למחוק את ${mediaType === 'video' ? 'הוידאו' : 'השמע'}?`)) {
                postServiceWorkerMessage({ type: 'DELETE_MEDIA_CACHE', payload: { contentName: lessonConfig.contentName, mediaType } });
            }
        }

        function normalizePlaybackTime(value) {
            const seconds = Number(value);
            return Number.isFinite(seconds) && seconds > 0 ? seconds : 0;
        }

        function getStoredProgress() {
            const keys = progressStorageKey === legacyProgressStorageKey
                ? [progressStorageKey]
                : [progressStorageKey, legacyProgressStorageKey].filter(Boolean);

            for (const key of keys) {
                try {
                    const raw = localStorage.getItem(key);
                    if (!raw) continue;
                    const parsed = JSON.parse(raw);
                    const time = normalizePlaybackTime(parsed?.time);
                    if (!time) continue;
                    return { time, isVideo: !!parsed.isVideo, updatedAt: parsed.updatedAt || 0, source: 'localStorage' };
                } catch {
                }
            }

            return null;
        }

        function clearLegacyStoredProgress() {
            if (!legacyProgressStorageKey || legacyProgressStorageKey === progressStorageKey) return;

            try {
                localStorage.removeItem(legacyProgressStorageKey);
            } catch {
            }
        }

        function saveStoredProgress(time, isVideo, force = false) {
            const normalizedTime = normalizePlaybackTime(time);
            if (!normalizedTime) return null;

            const existingProgress = getStoredProgress();
            if (!force && existingProgress && !hasMeaningfulProgressChange(existingProgress, normalizedTime, isVideo)) {
                return { ...existingProgress, changed: false };
            }

            const progress = {
                time: normalizedTime,
                isVideo: !!isVideo,
                updatedAt: Date.now(),
                source: 'localStorage'
            };

            try {
                localStorage.setItem(progressStorageKey, JSON.stringify(progress));
                clearLegacyStoredProgress();
            } catch (error) {
                console.warn('[Timekeeping] Local progress save failed.', error);
            }

            return { ...progress, changed: true };
        }

        function getLastKnownProgress() {
            const candidates = [];
            const indexedTime = normalizePlaybackTime(localData?.lastPlayed?.time);
            if (indexedTime) {
                addProgressCandidate(candidates, {
                    time: indexedTime,
                    isVideo: !!localData.lastPlayed.isVideo,
                    updatedAt: localData.lastPlayed.updatedAt || 0,
                    source: 'indexedDB'
                });
            }

            const storedProgress = getStoredProgress();
            if (storedProgress) addProgressCandidate(candidates, storedProgress);

            const serverTime = normalizePlaybackTime(lessonConfig.serverTime);
            if (serverTime) {
                addProgressCandidate(candidates, {
                    time: serverTime,
                    isVideo: lessonConfig.serverIsVideo ?? true,
                    updatedAt: lessonConfig.serverUpdatedAt || 0,
                    source: 'server'
                });
            }

            candidates.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
            return candidates[0] || null;
        }

        function sendProgressToServer(time, isVideo, updatedAt = Date.now()) {
            const form = document.getElementById('hiddenTimeForm');
            if (!form || !time) return;

            const formData = new FormData(form);
            formData.set('time', normalizePlaybackTime(time).toString());
            formData.set('isVideo', (!!isVideo).toString());
            formData.set('clientUpdatedAt', Math.trunc(updatedAt || Date.now()).toString());

            try {
                if (navigator.sendBeacon?.(form.getAttribute('action'), formData)) {
                    return;
                }
            } catch (error) {
                console.warn('[Timekeeping] sendBeacon progress save failed.', error);
            }

            fetch(form.getAttribute('action'), {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                keepalive: true
            }).catch(error => console.warn('[Timekeeping] Server progress save failed.', error));
        }

        function syncProgressCandidateToServer(candidate) {
            if (!candidate || candidate.source === 'server') return false;

            sendProgressToServer(candidate.time, candidate.isVideo, candidate.updatedAt);
            if (pendingServerProgress && (pendingServerProgress.updatedAt || 0) <= (candidate.updatedAt || 0) + 1000) {
                pendingServerProgress = null;
            }

            return true;
        }

        async function persistCurrentProgress(syncServer = false, force = false) {
            if (!player) return null;

            const time = normalizePlaybackTime(player.currentTime);
            if (!time) return null;

            const isVideo = getActiveMediaType() === 'video';
            const latestBeforeSave = getLastKnownProgress();
            const latestIsNewerThanThisPage = (latestBeforeSave?.updatedAt || 0) > pageLoadedAt + 1000;
            const activeOrRecent = isPlayerActivelyPlaying() || hasRecentPlaybackActivity();
            const materialChange = hasMeaningfulProgressChange(latestBeforeSave, time, isVideo);

            if (!force) {
                if (latestIsNewerThanThisPage && !activeOrRecent) {
                    if (syncServer) syncProgressCandidateToServer(latestBeforeSave);
                    return latestBeforeSave;
                }
                if (!activeOrRecent && !materialChange) {
                    if (syncServer) syncProgressCandidateToServer(pendingServerProgress || latestBeforeSave);
                    if (!pendingServerProgress) return latestBeforeSave;
                }
            }

            const progress = saveStoredProgress(time, isVideo, force);
            if (!progress) return null;

            if (progress.changed) {
                pendingServerProgress = progress;
            }

            if (localData && progress.changed) {
                localData.lastPlayed = progress;
            }

            const hasDownloadedMedia = localData?.videoStatus === 'completed' || localData?.audioStatus === 'completed';
            if (progress.changed && (lessonConfig.isOffline || hasDownloadedMedia)) {
                offlineVideoDB.saveTimestamp(lessonConfig.contentName, time, isVideo)
                    .catch(error => console.warn('[Timekeeping] IndexedDB progress save failed.', error));
            }

            if (syncServer && lessonConfig.isMember && !lessonConfig.isOffline) {
                const progressToSync = (progress.changed || force || materialChange) ? progress : pendingServerProgress;
                syncProgressCandidateToServer(progressToSync);
            }

            return progress;
        }

        function seekPlayerTo(time) {
            const normalizedTime = normalizePlaybackTime(time);
            if (!player || !normalizedTime) return;
            if (lessonConfig.hasExternalVideo) {
                player.once('ready', () => player.embed.seekTo(normalizedTime, true));
                return;
            }
            player.once('canplay', () => { player.currentTime = normalizedTime; });
            if (player.ready) player.currentTime = normalizedTime;
        }

        async function seekToLastKnownTime() {
            const progress = getLastKnownProgress();
            if (progress?.time) {
                console.log(`[Timekeeping] Seeking to ${progress.time}s from ${progress.source}.`);
                seekPlayerTo(progress.time);
            }
        }

        function startLocalTimeUpdater() {
            if (localTimeUpdater) clearInterval(localTimeUpdater);
            attachProgressActivityListeners();
            localTimeUpdater = setInterval(() => {
                persistCurrentProgress(false);
            }, 5000);
        }

        function flushCurrentProgress(stopUpdater = true) {
            if (stopUpdater && localTimeUpdater) {
                clearInterval(localTimeUpdater);
                localTimeUpdater = null;
            }
            persistCurrentProgress(true);
        }

        async function syncLocalTimeToServerOnLoad() {
            if (!lessonConfig.isMember || lessonConfig.isOffline) return;

            const progress = getLastKnownProgress();
            if (!progress || progress.source === 'server') return;

            const serverUpdatedAt = lessonConfig.serverUpdatedAt || 0;
            if (serverUpdatedAt && (progress.updatedAt || 0) + 1000 < serverUpdatedAt) return;

            sendProgressToServer(progress.time, progress.isVideo, progress.updatedAt);
        }

        async function initializeFirstPlayer() {
            console.log('[Init] Starting initial player load...');
            let initialTabIsVideo = lessonConfig.isVideoSelected;
            const progress = getLastKnownProgress();
            if (progress) {
                initialTabIsVideo = progress.isVideo && canAccessVideoPlayback();
            }
            if (!initialTabIsVideo && !lessonConfig.hasAudio && canAccessVideoPlayback()) {
                initialTabIsVideo = true;
            }

            if (lessonConfig.isOffline) {
                const videoAvailable = localData?.videoStatus === 'completed';
                const audioAvailable = localData?.audioStatus === 'completed';
                if (!videoAvailable && !audioAvailable) {
                    $('#player-wrapper').html('<div class="alert alert-warning text-center"><h3>אתה לא מחובר לאינטרנט</h3><p>השיעור הזה לא הורד למכשיר.</p></div>');
                    $('#download-container').hide();
                    return;
                }
                initialTabIsVideo = (initialTabIsVideo && videoAvailable) || !audioAvailable;
            }

            if (initialTabIsVideo && canAccessVideoPlayback()) {
                $('#videoB').addClass('active').tab('show');
                $('#audioB').removeClass('active');
                await initVideo();
            } else if (lessonConfig.hasAudio) {
                $('#audioB').addClass('active').tab('show');
                $('#videoB').removeClass('active');
                initAudio();
            } else {
                console.log('[Init] No media available to load.');
                return;
            }

            await seekToLastKnownTime();
            startLocalTimeUpdater();
            await updateDownloadUI();
        }

        document.addEventListener('DOMContentLoaded', async () => {
            try {
                console.log('[Init] DOM content loaded.');
                localData = await offlineVideoDB.getLesson(lessonConfig.contentName);
                await syncLocalTimeToServerOnLoad();

                $('a[data-toggle="tab"]').on('shown.bs.tab', async function (e) {
                    if (player?.currentTime > 0) {
                        transitionTime = player.currentTime;
                        await persistCurrentProgress(false, true);
                    }
                    const targetId = $(e.target).attr('id');
                    console.log(`[Event] User switched tab to: ${targetId}, captured time: ${transitionTime}`);
                    clearPlayer();
                    if (targetId === 'videoB' && lessonConfig.hasAnyVideo) await initVideo();
                    else if (targetId === 'audioB' && lessonConfig.hasAudio) initAudio();
                    if (transitionTime > 0) { seekPlayerTo(transitionTime); transitionTime = 0; }
                    else { await seekToLastKnownTime(); }
                    if (player) startLocalTimeUpdater();
                    await updateDownloadUI();
                });

                $(document).on('click', '#downloadBtn', handleDownloadClick);
                $(document).on('click', '#cancelDownloadBtn', () => {
                    postServiceWorkerMessage({
                        type: 'CANCEL_DOWNLOAD',
                        payload: { contentName: lessonConfig.contentName, mediaType: getActiveMediaType() }
                    });
                });
                $(document).on('click', '.delete-media-btn', function() { handleDeleteClick($(this).data('media-type')); });
                $(document).on('click', '.resolution-choice-btn', function() { startVideoDownload($(this).data('resolution')); });
                await initializeFirstPlayer();
            } catch (error) { console.error("A critical error occurred during page initialization:", error); $('#player-wrapper').html('<div class="alert alert-danger">אירעה שגיאה חמורה בטעינת הדף. נסה לרענן.</div>'); }
        });


        function isDuplicateDownloadMessage(data) {
            if (!data?.messageId) return false;
            if (handledDownloadMessageIds.includes(data.messageId)) return true;
            handledDownloadMessageIds.push(data.messageId);
            if (handledDownloadMessageIds.length > 50) handledDownloadMessageIds.shift();
            return false;
        }

        async function handleDownloadMessage(data) {
            if (isDuplicateDownloadMessage(data)) return;

            const { type, payload } = data || {};
            if (!payload || payload.contentName !== lessonConfig.contentName) return;

            if (type === 'DOWNLOAD_PROGRESS') {
                if (payload.mediaType !== getActiveMediaType()) return;
                const pb = document.getElementById('progress-bar');
                if (pb) { pb.style.width = payload.progress + '%'; pb.textContent = payload.progress + '%'; }
            } else if (['DOWNLOAD_COMPLETE', 'DOWNLOAD_FAILED', 'DOWNLOAD_CANCELLED', 'DELETE_MEDIA_CACHE_COMPLETE'].includes(type)) {
                const activeMediaType = $('#videoB').hasClass('active') ? 'video' : 'audio';
                const shouldReloadActivePlayer = type === 'DOWNLOAD_COMPLETE' && payload.mediaType === activeMediaType;
                const reloadProgress = shouldReloadActivePlayer ? await persistCurrentProgress(false, true) : null;
                localData = await offlineVideoDB.getLesson(lessonConfig.contentName);
                await updateDownloadUI();

                if (shouldReloadActivePlayer) {
                    console.log(`[Broadcast] Player reload triggered by ${activeMediaType} download completion.`);
                    clearPlayer();
                    if (payload.mediaType === 'video') {
                        await initVideo();
                    } else {
                        initAudio();
                    }
                    const reloadTime = normalizePlaybackTime(reloadProgress?.time);
                    if (reloadTime) {
                        seekPlayerTo(reloadTime);
                    } else {
                        await seekToLastKnownTime();
                    }
                    startLocalTimeUpdater();
                }
            }
        }

        if (broadcast) {
            broadcast.onmessage = (event) => { handleDownloadMessage(event.data); };
        }

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.addEventListener('message', (event) => { handleDownloadMessage(event.data); });
            navigator.serviceWorker.addEventListener('controllerchange', resendOfflineMediaPlaybackState);
        }

        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'hidden') {
                flushCurrentProgress(false);
            } else if (!localTimeUpdater && player) {
                startLocalTimeUpdater();
            }
        });
        window.addEventListener('pageshow', resendOfflineMediaPlaybackState);
        window.addEventListener('pagehide', () => {
            if (offlineMediaPlaybackEnabled) {
                postOfflineMediaState('DISABLE_OFFLINE_MEDIA');
            }
            flushCurrentProgress(true);
        });
        window.addEventListener('beforeunload', () => flushCurrentProgress(true));
    </script>
