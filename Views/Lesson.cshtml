        function setDownloadStartInProgress(mediaType, inProgress) {
            if (inProgress) {
                downloadStartInProgress.add(mediaType);
            } else {
                downloadStartInProgress.delete(mediaType);
            }
        }

        function bumpMediaOperationVersion() {
            mediaOperationVersion += 1;
            return mediaOperationVersion;
        }

        function isCurrentMediaOperation(version) {
            return version === mediaOperationVersion;
        }

        function setPendingMediaDelete(mediaType, inProgress) {
            if (!mediaType) return;
            if (inProgress) {
                pendingMediaDeletes.add(mediaType);
            } else {
                pendingMediaDeletes.delete(mediaType);
            }
        }

        function getMediaOperationKey(mediaType) {
            return `${lessonConfig.contentName}:${mediaType || ''}`;
        }

        function markLocalMediaDeleteHandled(mediaType) {
            if (!mediaType) return;
            locallyHandledMediaDeleteCompletions.add(getMediaOperationKey(mediaType));
        }

        function consumeLocalMediaDeleteHandled(mediaType) {
            if (!mediaType) return false;
            const key = getMediaOperationKey(mediaType);
            const handledLocally = locallyHandledMediaDeleteCompletions.has(key);
            if (handledLocally) {
                locallyHandledMediaDeleteCompletions.delete(key);
            }
            return handledLocally;
        }

        function getPlayerWrapperHasContent() {
            const wrapper = document.getElementById('player-wrapper');
            return !!wrapper && wrapper.childElementCount > 0;
        }

        function ensurePlayerHasContent() {
            if (getPlayerWrapperHasContent()) return;
            $('#player-wrapper').html('<div class="alert alert-warning text-center">המדיה אינה זמינה כרגע. נסה לרענן את הדף.</div>');
        }

        function getMediaStatus(record, mediaType) {
            if (pendingMediaDeletes.has(mediaType)) return 'none';
            if (!record) return 'none';
            return mediaType === 'video'
                ? (record.videoStatus || 'none')
                : (record.audioStatus || 'none');
        }

        function getOtherMediaType(mediaType) {
            return mediaType === 'video' ? 'audio' : 'video';
        }

        function isStoredMediaStatus(status) {
            return status === 'completed' || status === 'downloading';
        }

        function getMediaLabel(mediaType) {
            return mediaType === 'video' ? 'וידאו' : 'שמע';
        }

        function getBlockingMedia(record, requestedMediaType) {
            const otherMediaType = getOtherMediaType(requestedMediaType);
            const otherStatus = getMediaStatus(record, otherMediaType);
            return isStoredMediaStatus(otherStatus)
                ? { mediaType: otherMediaType, status: otherStatus }
                : null;
        }

        async function cleanupNormalizedMediaCaches(normalized) {
            if (!normalized?.removedMediaTypes?.length || typeof offlineVideoDB.cleanupRemovedMedia !== 'function') {
                return;
            }

            try {
                await offlineVideoDB.cleanupRemovedMedia(normalized.removedMediaTypes.map(mediaType => ({
                    contentName: lessonConfig.contentName,
                    mediaType
                })));
            } catch (error) {
                console.warn('[PWA] Failed to clean normalized media cache.', error);
            }
        }

        function queryDownloadStatus(mediaType) {
            postServiceWorkerMessage({
                type: 'QUERY_DOWNLOAD_STATUS',
                payload: { contentName: lessonConfig.contentName, mediaType }
            });
        }

        async function refreshLocalData() {
            try {
                if (typeof offlineVideoDB.normalizeLesson === 'function') {
                    const normalized = await offlineVideoDB.normalizeLesson(lessonConfig.contentName, getActiveMediaType());
                    await cleanupNormalizedMediaCaches(normalized);
                    localData = normalized?.record || null;
                } else {
                    localData = await offlineVideoDB.getLesson(lessonConfig.contentName);
                }
            } catch (error) {
                console.warn('[PWA] Failed to read local lesson data.', error);
            }

            return localData || null;
        }

        async function updateDownloadUI() {
          const container = document.getElementById('download-container');
          const statusEl = document.getElementById('download-status');
          if (!container) return;
          clearDownloadStatusRefresh();

          const hideStatus = () => { if (statusEl) statusEl.style.display = 'none'; };


