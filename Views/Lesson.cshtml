                $('#resolution-options-container').html(opts);
                $('#resolutionModal').modal('show');
            } else {
                startAudioDownload();
            }
        }

        async function startVideoDownload(resolution) {
            $('#resolutionModal').modal('hide');
            const mediaType = 'video';
            try {
                if (!navigator.serviceWorker?.controller) {
                    throw new Error('Service Worker controller is unavailable.');
                }

                const { playlistUrl, urls } = await buildHlsDownloadUrls(resolution);
                const metadata = { ...lessonConfig.pwaMetaData, mediaType, resolution, hlsQualityPlaylistUrl: playlistUrl };
                await offlineVideoDB.startDownload(metadata, mediaType, resolution);
                await updateDownloadUI();
                postServiceWorkerMessage({ type: 'CACHE_MEDIA', payload: { urls, metadata } });
            } catch (error) {
                console.error('Video download start failed:', error);
                await offlineVideoDB.updateMediaStatus(lessonConfig.contentName, mediaType, 'none');
                await updateDownloadUI();
            }
        }

        async function startAudioDownload() {
            const mediaType = 'audio';
            try {
                if (!navigator.serviceWorker?.controller) {
                    throw new Error('Service Worker controller is unavailable.');
                }

                const metadata = { ...lessonConfig.pwaMetaData, mediaType, resolution: null, audioUrl: lessonConfig.audioUrl };
                await offlineVideoDB.startDownload(metadata, mediaType, null);
                await updateDownloadUI();
                postServiceWorkerMessage({ type: 'CACHE_MEDIA', payload: { urls: [lessonConfig.audioUrl], metadata } });
            } catch (error) {
                console.error('Audio download start failed:', error);
