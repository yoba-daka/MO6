    <script>
        // --- C# variables are now passed into a single, clean config object ---
        const lessonConfig = {
            isMember: @(memberLogged.ToString().ToLower()),
            hasActiveMembership: @(hasActiveMembership.ToString().ToLower()),
            isMembersOnly: @(Model.MembersOnly.ToString().ToLower()),
            hasVideo: @(hasVideo.ToString().ToLower()),
            hasAnyVideo: @(hasAnyVideo.ToString().ToLower()),
            hasAudio: @(hasAudio.ToString().ToLower()),
            hasExternalVideo: @(hasExternalVideo.ToString().ToLower()),
            externalLink: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(externalLink)),
            isVideoSelected: @(videoSelected.ToString().ToLower()),
            contentName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ContentName)),
            playerLabel: @Html.Raw(System.Text.Json.JsonSerializer.Serialize("נגן שיעור - " + Model.Title)),
            isOffline: !navigator.onLine,
            hlsMasterPlaylistUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hasVideo ? $"/media/hls/{System.Uri.EscapeDataString(Model.ContentName)}/index.m3u8" : "")),
            audioUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hasAudio ? $"/media/audio/{System.Uri.EscapeDataString(Model.ContentName)}/audio.mp3" : "")),
            shortAudioUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hasAudio && MembersOnly && !hasActiveMembership ? $"/media/audio/{System.Uri.EscapeDataString(Model.ContentName)}/audio-short.mp3" : "")),
            memberId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(memberID)),

            pwaMetaData: {
                contentName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ContentName)),
                title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Title)),
                url: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Url())),
                imageUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.GetOptimizedCropUrl(Model.Image, "small"))),
                duration: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Duration)),
                requiresMembership: @(Model.MembersOnly.ToString().ToLower())
            },
            serverTime: @(timeKeeper != null ? timeKeeper.time : "null"),
            serverIsVideo: @(timeKeeper != null ? timeKeeper.isVideo.ToString().ToLower() : "null"),
            serverUpdatedAt: @(timeKeeper != null ? new DateTimeOffset(DateTime.SpecifyKind(timeKeeper.date, DateTimeKind.Utc)).ToUnixTimeMilliseconds() : 0),
            qualities: { q240: @(h240? q240 : -1), q360: @(h360? q360 : -1), q480: @(h480? q480 : -1), q720: @(h720? q720 : -1), q1080: @(h1080? q1080 : -1) }
        };

        // --- Global script variables ---
        var player, localTimeUpdater, localData, audioRecoveryCleanup, videoRecoveryCleanup, pendingServerProgress = null;
        var transitionTime = 0;
        const broadcast = 'BroadcastChannel' in window ? new BroadcastChannel('download_channel') : null;
        const progressOwner = lessonConfig.memberId ? `member:${lessonConfig.memberId}` : 'anonymous';
        const progressStorageKey = `lesson-progress:${progressOwner}:${lessonConfig.contentName}`;
        const legacyProgressStorageKey = `lesson-progress:${lessonConfig.contentName}`;
        const handledDownloadMessageIds = [];
        const pageLoadedAt = Date.now();
        const progressSaveMinDeltaSeconds = 1;
        const progressActivityGraceMs = 30000;
        let lastPlaybackActivityAt = 0;
        let offlineMediaPlaybackEnabled = false;

        // --- Player Initialization and Helper Functions ---
        function markPlaybackActivity() {
            lastPlaybackActivityAt = Date.now();
        }

        function hasRecentPlaybackActivity() {
            return lastPlaybackActivityAt > 0 && Date.now() - lastPlaybackActivityAt < progressActivityGraceMs;
        }

        function isPlayerActivelyPlaying() {
            return !!player && !player.paused && !player.ended;
        }

        function hasMeaningfulProgressChange(existing, time, isVideo) {
            if (!existing) return true;
            return existing.isVideo !== !!isVideo || Math.abs(normalizePlaybackTime(existing.time) - normalizePlaybackTime(time)) >= progressSaveMinDeltaSeconds;
        }

        function canAccessVideoPlayback() {
            return lessonConfig.hasAnyVideo && (!lessonConfig.isMembersOnly || lessonConfig.hasActiveMembership);
        }

        function addProgressCandidate(candidates, candidate) {
            if (!candidate) return;
            if (candidate.isVideo && !canAccessVideoPlayback()) return;
            candidates.push(candidate);
        }

        function attachProgressActivityListeners() {
            if (!player || player.__mo6ProgressActivityAttached || typeof player.on !== 'function') return;

            ['play', 'playing', 'timeupdate', 'seeked'].forEach(eventName => {
                player.on(eventName, markPlaybackActivity);
            });
            player.__mo6ProgressActivityAttached = true;
        }

        function postOfflineMediaState(type) {
            try {
                navigator.serviceWorker?.controller?.postMessage({
                    type,
                    payload: { contentName: lessonConfig.contentName }
                });
            } catch (error) {
                console.warn('[OfflineMedia] Failed to update service worker media state.', error);
            }
        }

        function setOfflineMediaPlaybackEnabled(enabled) {
            const normalizedEnabled = !!enabled;
            if (offlineMediaPlaybackEnabled === normalizedEnabled) return;

            offlineMediaPlaybackEnabled = normalizedEnabled;
            postOfflineMediaState(normalizedEnabled ? 'ENABLE_OFFLINE_MEDIA' : 'DISABLE_OFFLINE_MEDIA');
        }

        function resendOfflineMediaPlaybackState() {
            if (offlineMediaPlaybackEnabled) {
                postOfflineMediaState('ENABLE_OFFLINE_MEDIA');
            }
        }

        function getYoutubeId(url) {
            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[2].length === 11) ? match[2] : null;
        }

        function getHlsPlaybackUrl(forceRefresh = false, sourceUrl = null) {
            const playbackUrl = sourceUrl || lessonConfig.hlsMasterPlaylistUrl;
            if (!playbackUrl) return '';

            const url = new URL(playbackUrl, window.location.href);
            if (forceRefresh && !lessonConfig.isOffline) {
                url.searchParams.set('r', Date.now().toString());
            }

            return url.href;
        }

        function getAudioPlaybackUrl(baseUrl, forceRefresh = false) {
            if (!baseUrl) return '';

            const url = new URL(baseUrl, window.location.href);
            if (forceRefresh && !lessonConfig.isOffline) {
                url.searchParams.set('r', Date.now().toString());
            }

            return url.href;
        }

        function restoreVideoPlayback(videoElement, resumeTime, shouldResume) {
            const normalizedResumeTime = normalizePlaybackTime(resumeTime);
            let restored = false;
            let seekAttempts = 0;
            let timeout = null;

            const cleanup = () => {
                if (timeout) {
                    clearTimeout(timeout);
                    timeout = null;
                }
                videoElement.removeEventListener('loadedmetadata', finish);
                videoElement.removeEventListener('canplay', finish);
            };

            const finish = async () => {
                if (restored) return;
                if (timeout) {
                    clearTimeout(timeout);
                    timeout = null;
                }

                try {
                    if (normalizedResumeTime > 0) {
                        videoElement.currentTime = normalizedResumeTime;
                    }
                } catch (error) {
                    seekAttempts += 1;
                    if (seekAttempts < 4) {
                        timeout = setTimeout(finish, 750);
                        return;
                    }
                    console.warn('[HLS] Recovery seek failed.', error);
                }

                restored = true;
                cleanup();

                if (shouldResume) {
                    try {
                        await videoElement.play();
                    } catch (error) {
                        console.warn('[HLS] Recovery play() failed.', error);
                    }
                }
            };

            videoElement.addEventListener('loadedmetadata', finish, { once: true });
            videoElement.addEventListener('canplay', finish, { once: true });
            timeout = setTimeout(finish, 2500);
        }

        function createVideoSourceRefreshGuard(videoElement, reloadSource) {
            let refreshing = false;
            let retries = 0;
            let retryWindowStartedAt = Date.now();

            return async (reason) => {
                if (refreshing || videoElement.ended) return;

                const now = Date.now();
                if (now - retryWindowStartedAt > 90000) {
                    retries = 0;
                    retryWindowStartedAt = now;
                }

                if (retries >= 4) {
                    console.warn(`[HLS] Source refresh limit reached. reason=${reason}`);
                    return;
                }

                refreshing = true;
                retries += 1;

                const resumeTime = normalizePlaybackTime(videoElement.currentTime);
                const shouldResume = !videoElement.paused && !videoElement.ended;

                try {
                    await reloadSource(reason, resumeTime, shouldResume);
                } catch (error) {
                    console.warn('[HLS] Source refresh failed.', error);
                } finally {
                    setTimeout(() => { refreshing = false; }, 1500);
                }
            };
        }

        function attachVideoRecovery(videoElement, recoverSource) {
            if (!videoElement) return null;

            let waitingTimer = null;
            let watchdogTimer = null;
            let lastTime = 0;
            let stagnantChecks = 0;

            const clearWaitingTimer = () => {
                if (waitingTimer) {
                    clearTimeout(waitingTimer);
                    waitingTimer = null;
                }
            };

            const resetProgressState = () => {
                clearWaitingTimer();
                stagnantChecks = 0;
                lastTime = videoElement.currentTime || 0;
            };

            const scheduleRecovery = (reason, delayMs = 6000) => {
                clearWaitingTimer();
                waitingTimer = setTimeout(() => {
                    if (!videoElement.paused && !videoElement.ended && videoElement.readyState < 3) {
                        recoverSource(reason);
                    }
                }, delayMs);
            };

            const handleWaiting = () => scheduleRecovery('waiting-timeout');
            const handleStalled = () => scheduleRecovery('stalled-event', 4000);
            const handleError = () => recoverSource('media-error');
            const handleTimeUpdate = () => {
                markPlaybackActivity();
                lastTime = videoElement.currentTime || 0;
                stagnantChecks = 0;
                clearWaitingTimer();
            };

            const handleWatchdog = () => {
                if (videoElement.paused || videoElement.ended || videoElement.seeking || videoElement.readyState < 2) {
                    stagnantChecks = 0;
                    lastTime = videoElement.currentTime || 0;
                    return;
                }

                const currentTime = videoElement.currentTime || 0;
                if (Math.abs(currentTime - lastTime) < 0.05) {
                    stagnantChecks += 1;
                    if (stagnantChecks >= 3) {
                        recoverSource('watchdog-stalled');
                    }
                } else {
                    stagnantChecks = 0;
                    lastTime = currentTime;
                }
            };

            videoElement.addEventListener('waiting', handleWaiting);
            videoElement.addEventListener('stalled', handleStalled);
            videoElement.addEventListener('error', handleError);
            videoElement.addEventListener('canplay', resetProgressState);
            videoElement.addEventListener('playing', resetProgressState);
            videoElement.addEventListener('seeked', resetProgressState);
            videoElement.addEventListener('timeupdate', handleTimeUpdate);

            watchdogTimer = setInterval(handleWatchdog, 3000);
            resetProgressState();

            return () => {
                clearWaitingTimer();
                if (watchdogTimer) {
                    clearInterval(watchdogTimer);
                    watchdogTimer = null;
                }
                videoElement.removeEventListener('waiting', handleWaiting);
                videoElement.removeEventListener('stalled', handleStalled);
                videoElement.removeEventListener('error', handleError);
                videoElement.removeEventListener('canplay', resetProgressState);
                videoElement.removeEventListener('playing', resetProgressState);
                videoElement.removeEventListener('seeked', resetProgressState);
                videoElement.removeEventListener('timeupdate', handleTimeUpdate);
            };
        }

        function getHlsErrorStatus(data) {
            return Number(data?.response?.code || data?.networkDetails?.status || data?.error?.code || 0);
        }

        async function initVideo() {
            console.log('[Player] Initializing VIDEO player...');
            showVidBanner();

            if (!canAccessVideoPlayback()) {
                setOfflineMediaPlaybackEnabled(false);
                $('#player-wrapper').html('<div class="alert alert-warning text-center">הוידאו זמין למנויים בלבד.</div>');
                return;
            }

            if (lessonConfig.hasExternalVideo) {
                setOfflineMediaPlaybackEnabled(false);
                const youtubeId = getYoutubeId(lessonConfig.externalLink);
                $('#player-wrapper').html(`<div id="player" data-plyr-provider="youtube" data-plyr-embed-id="${youtubeId}" aria-label="${lessonConfig.playerLabel}"></div>`);
                player = new Plyr('#player', { title: lessonConfig.playerLabel, keyboard: { focused: true, global: true } });
                return;
            }

            const downloadedResolution = localData?.videoStatus === 'completed' ? localData.videoResolution : null;
            if (lessonConfig.isOffline && !downloadedResolution) {
                $('#player-wrapper').html('<div class="alert alert-warning text-center"><h3>אתה לא מחובר לאינטרנט</h3><p>הוידאו של שיעור זה לא הורד למכשיר.</p></div>');
                return;
            }
            $('#player-wrapper').html(`<video poster="" id="player" playsinline controls aria-label="${lessonConfig.playerLabel}"></video>`);
            const video = document.querySelector('#player');
            const downloadedQualityIndex = downloadedResolution ? lessonConfig.qualities['q' + downloadedResolution.replace('p', '')] : -1;
            const downloadedPlaylistUrl = downloadedResolution && localData?.hlsQualityPlaylistUrl
                ? localData.hlsQualityPlaylistUrl.split('?')[0]
                : null;
            const hlsSourceUrl = downloadedPlaylistUrl || lessonConfig.hlsMasterPlaylistUrl;
            setOfflineMediaPlaybackEnabled(!!downloadedPlaylistUrl);
            player = new Plyr(video, {
                title: lessonConfig.playerLabel,
                controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'captions', 'settings', 'pip', 'airplay', 'fullscreen'],
                settings: ['captions', 'quality', 'speed'], keyboard: { focused: true, global: true },
                i18n: { qualityLabel: { '-1': 'אוטומטי', 1080: `1080p${downloadedResolution === '1080p'?' <i class="fa fa-check-circle text-success"></i>':''}`, 720: `720p${downloadedResolution === '720p'?' <i class="fa fa-check-circle text-success"></i>':''}`, 480: `480p${downloadedResolution === '480p'?' <i class="fa fa-check-circle text-success"></i>':''}`, 360: `360p${downloadedResolution === '360p'?' <i class="fa fa-check-circle text-success"></i>':''}`, 240: `240p${downloadedResolution === '240p'?' <i class="fa fa-check-circle text-success"></i>':''}` } }
            });

            const canUseNativeHls = video.canPlayType('application/vnd.apple.mpegurl') || video.canPlayType('application/x-mpegURL');

            if (canUseNativeHls) {
                const recoverNativeSource = createVideoSourceRefreshGuard(video, async (reason, resumeTime, shouldResume) => {
                    console.warn(`[HLS] Refreshing native source. reason=${reason}, time=${resumeTime}`);
                    video.pause();
                    video.src = getHlsPlaybackUrl(true, hlsSourceUrl);
                    video.load();
                    restoreVideoPlayback(video, resumeTime, shouldResume);
                });
                videoRecoveryCleanup = attachVideoRecovery(video, recoverNativeSource);
                video.src = getHlsPlaybackUrl(false, hlsSourceUrl);
                return;
            }

            if (window.Hls && Hls.isSupported()) {
                const recoverHlsSource = createVideoSourceRefreshGuard(video, async (reason, resumeTime, shouldResume) => {
                    console.warn(`[HLS] Refreshing source. reason=${reason}, time=${resumeTime}`);
                    if (window.hls) {
                        window.hls.destroy();
                        window.hls = null;
                    }
                    createHlsInstance(true, resumeTime, shouldResume);
                });

                const createHlsInstance = (forceRefresh = false, resumeTime = 0, shouldResume = false) => {
                const hls = new Hls({ debug: false });
                if (!downloadedPlaylistUrl && downloadedQualityIndex !== -1) hls.startLevel = downloadedQualityIndex;
                hls.loadSource(getHlsPlaybackUrl(forceRefresh, hlsSourceUrl));
                hls.on(Hls.Events.MANIFEST_PARSED, () => {
                    if (!downloadedPlaylistUrl && downloadedQualityIndex !== -1) hls.currentLevel = downloadedQualityIndex;
                    if (resumeTime > 0 || shouldResume) {
                        restoreVideoPlayback(video, resumeTime, shouldResume);
                    }
                });
                hls.on(Hls.Events.ERROR, (event, data) => {
                    const status = getHlsErrorStatus(data);
                    const isNetworkError = data?.type === Hls.ErrorTypes.NETWORK_ERROR;
                    const shouldRefreshSource = isNetworkError && (data?.fatal || status === 0 || status === 401 || status === 403 || status === 404);

                    if (shouldRefreshSource) {
                        recoverHlsSource(`network-${status || 'unknown'}`);
                        return;
                    }

                    if (!data?.fatal) return;

                    console.warn('[HLS] Fatal playback error.', data);
                    if (data.type === Hls.ErrorTypes.NETWORK_ERROR) {
                        recoverHlsSource(`network-${status || 'unknown'}`);
                    } else if (data.type === Hls.ErrorTypes.MEDIA_ERROR) {
                        hls.recoverMediaError();
                    } else {
                        hls.destroy();
                        window.hls = null;
                        $('#player-wrapper').html('<div class="alert alert-danger">שגיאה בטעינת הוידאו. נסה לרענן את הדף.</div>');
                    }
                });
                hls.attachMedia(video);
                window.hls = hls;
                };

                videoRecoveryCleanup = attachVideoRecovery(video, recoverHlsSource);
                createHlsInstance(false);
                return;
            }

            setOfflineMediaPlaybackEnabled(false);

            $('#player-wrapper').html('<div class="alert alert-danger">הדפדפן אינו תומך בניגון הוידאו.</div>');
        }


