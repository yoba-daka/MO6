@using MyProject12;
@using MyProject12.Models;
@using Umbraco.Cms.Core.Security;
@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment WebHostEnvironment
@inject LessonBlobService BlobService
@inject IMemberManager _memberManager
@inject DB db

@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Lesson>
@using MosheSharon;
@{
    TimeKeeper timeKeeper = null;
    bool memberLogged = _memberManager.IsLoggedIn();
    bool hasActiveMembership = false;
    string sasToken = "";
    var MembersOnly = Model.MembersOnly;
    string memberEmail = "";
    string memberID = "";

    if (memberLogged)
    {
        var member = await _memberManager.GetCurrentMemberAsync();
        memberEmail = member.Email;
        memberID = member.Id;
        var membership = db.Memberships.FirstOrDefault(x => x.memberID == memberID);
        if (membership != null) hasActiveMembership = !membership.Expired;
    }
    if (memberLogged)
    {
        timeKeeper = db.getTimeKeeper(memberID, Model.Id);
    }
    if (hasActiveMembership || !MembersOnly)
    {
        if (MembersOnly)
        {
            if (!string.IsNullOrEmpty(memberEmail))
            {
                sasToken = BlobService.GenerateMemberContainerSas(Model.ContentName, memberEmail);
            }
        }
        else
        {
            sasToken = BlobService.GenerateUnlimitedSas(Model.ContentName, "*");
        }
    }

    Layout = "master.cshtml";

    dynamic parent = Model.Parent.ContentType.Alias == "lessonGroup" ? Model.Parent.Parent : Model.Parent;
    BlobService.setDuration(Model);

    // Prepare variables for the script block
    bool hasExternalVideo = !string.IsNullOrEmpty(Model.Youtube);
    string externalLink = Model.Youtube ?? "";
    bool hasVideo = hasExternalVideo ? false : BlobService.BlobExists(Model.ContentName, "index.m3u8");
    bool hasAudio = BlobService.BlobExists(Model.ContentName, "audio.mp3");
    bool hasAnyVideo = hasVideo || hasExternalVideo;
    bool videoSelected = hasAnyVideo == false ? false : hasActiveMembership == true ? true : MembersOnly ? false : true;
    videoSelected = timeKeeper != null ? timeKeeper.isVideo : videoSelected;

    bool h240 = hasVideo ? BlobService.BlobExists(Model.ContentName, "240p.m3u8") : false;
    bool h360 = hasVideo ? BlobService.BlobExists(Model.ContentName, "360p.m3u8") : false;
    bool h480 = hasVideo ? BlobService.BlobExists(Model.ContentName, "480p.m3u8") : false;
    bool h720 = hasVideo ? BlobService.BlobExists(Model.ContentName, "720p.m3u8") : false;
    bool h1080 = hasVideo ? BlobService.BlobExists(Model.ContentName, "1080p.m3u8") : false;

    int q240 = 0;
    int q360 = h240 ? 1 : 0;
    int q480 = h240 ? h360 ? 2 : 1 : 0;
    int q720 = h240 ? h360 ? h480 ? 3 : 2 : 1 : 0;
    int q1080 = h240 ? h360 ? h480 ? h720 ? 4 : 3 : 2 : 1 : 0;
}

