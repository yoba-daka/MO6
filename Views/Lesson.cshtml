@using MyProject12;
@using MyProject12.Models;
@using Microsoft.EntityFrameworkCore
@using Umbraco.Cms.Core.Security;
@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment WebHostEnvironment
@inject LessonBlobService BlobService
@inject IMemberManager _memberManager
@inject DB db

@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Lesson>
@using MosheSharon;
@{
    TimeKeeper timeKeeper = null;
    bool memberLogged = _memberManager.IsLoggedIn();
    bool hasActiveMembership = false;
    var MembersOnly = Model.MembersOnly;
    string memberID = "";
    Membership activeMembership = null;

    if (memberLogged)
    {
        var member = await _memberManager.GetCurrentMemberAsync();
        if (member != null)
        {
            memberID = member.Id;
            activeMembership = await db.Memberships
                .AsNoTracking()
                .GetPreferredMembershipAsync(memberID, Context.RequestAborted);
            hasActiveMembership = activeMembership != null && activeMembership.expiration >= DateTime.Now;
        }
    }
    if (memberLogged && !string.IsNullOrWhiteSpace(memberID))
    {
        timeKeeper = await db.TimeKeepers
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.memberID == memberID && x.lessonId == Model.Id, Context.RequestAborted);
    }
    Layout = "master.cshtml";

    dynamic parent = Model.Parent.ContentType.Alias == "lessonGroup" ? Model.Parent.Parent : Model.Parent;
    BlobService.setDuration(Model);

    // Prepare variables for the script block
    bool hasExternalVideo = !string.IsNullOrEmpty(Model.Youtube);
    string externalLink = Model.Youtube ?? "";
    Task<bool> hasVideoTask = hasExternalVideo
        ? Task.FromResult(false)
        : BlobService.BlobExistsAsync(Model.ContentName, "index.m3u8", Context.RequestAborted);
    Task<bool> hasAudioTask = BlobService.BlobExistsAsync(Model.ContentName, "audio.mp3", Context.RequestAborted);
    await Task.WhenAll(hasVideoTask, hasAudioTask);

    bool hasVideo = await hasVideoTask;
    bool hasAudio = await hasAudioTask;
    bool hasAnyVideo = hasVideo || hasExternalVideo;
    bool videoSelected = hasAnyVideo == false ? false : hasActiveMembership == true ? true : MembersOnly ? false : true;
    videoSelected = timeKeeper != null ? timeKeeper.isVideo : videoSelected;

    Task<bool> h240Task = hasVideo ? BlobService.BlobExistsAsync(Model.ContentName, "240p.m3u8", Context.RequestAborted) : Task.FromResult(false);
    Task<bool> h360Task = hasVideo ? BlobService.BlobExistsAsync(Model.ContentName, "360p.m3u8", Context.RequestAborted) : Task.FromResult(false);
    Task<bool> h480Task = hasVideo ? BlobService.BlobExistsAsync(Model.ContentName, "480p.m3u8", Context.RequestAborted) : Task.FromResult(false);
    Task<bool> h720Task = hasVideo ? BlobService.BlobExistsAsync(Model.ContentName, "720p.m3u8", Context.RequestAborted) : Task.FromResult(false);
    Task<bool> h1080Task = hasVideo ? BlobService.BlobExistsAsync(Model.ContentName, "1080p.m3u8", Context.RequestAborted) : Task.FromResult(false);
    await Task.WhenAll(h240Task, h360Task, h480Task, h720Task, h1080Task);

    bool h240 = await h240Task;
    bool h360 = await h360Task;
    bool h480 = await h480Task;
    bool h720 = await h720Task;
    bool h1080 = await h1080Task;

    int q240 = 0;
    int q360 = h240 ? 1 : 0;
    int q480 = h240 ? h360 ? 2 : 1 : 0;
    int q720 = h240 ? h360 ? h480 ? 3 : 2 : 1 : 0;
    int q1080 = h240 ? h360 ? h480 ? h720 ? 4 : 3 : 2 : 1 : 0;
    string blobPreconnectOrigin = BlobService.GetBlobServiceOrigin();
}

