              </button>`;
          } else if (mediaStatus === 'completed') {
            const resText = (mediaType === 'video' && localData && localData.videoResolution) ? ` (${localData.videoResolution})` : '';
            container.innerHTML = `
              <div class="d-flex align-items-center justify-content-center" style="gap:15px;">
                <p class="text-success m-0 d-inline-flex align-items-center" style="gap:.4rem;">
                  <i class="fa fa-check-circle" aria-hidden="true"></i>
                  ${mediaType === 'video' ? 'הוידאו' : 'השמע'} הורד${resText}
                </p>
                <button class="btn btn-danger btn-sm btn-round delete-media-btn" data-media-type="${mediaType}">
                  <i class="fa fa-trash" aria-hidden="true"></i>
                  מחק
                </button>
              </div>`;
          } else if (mediaStatus === 'downloading') {
            if (statusEl) {
              statusEl.style.display = 'block';
              statusEl.innerHTML = `
                <div class="progress rounded" style="height:20px;">
                  <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width:0%;">0%</div>
                </div>
                <button class="btn btn-danger btn-round mt-2 mb-4" id="cancelDownloadBtn">
                  <i class="fa fa-times" aria-hidden="true"></i>
                  בטל הורדה
                </button>`;
            }
            queryDownloadStatus(mediaType);
            scheduleDownloadStatusRefresh();
          } else if (blockingMedia) {
            container.innerHTML = `
              <button class="btn btn-secondary btn-round d-inline-flex align-items-center" disabled style="gap:.4rem;">
                <i class="fa fa-lock" aria-hidden="true"></i>
                הורדת ${getMediaLabel(mediaType)}
              </button>
              <small class="d-block mt-2">${getMediaLabel(blockingMedia.mediaType)} כבר שמור במכשיר. ניתן לשמור קובץ מדיה אחד בלבד לכל שיעור.</small>`;
            if (blockingMedia.status === 'downloading') {
              queryDownloadStatus(blockingMedia.mediaType);
              scheduleDownloadStatusRefresh();
            }
          } else {
            container.innerHTML = `
              <button id="downloadBtn" class="btn btn-primary btn-round d-inline-flex align-items-center" style="gap:.4rem;">
                <i class="fa fa-download" aria-hidden="true"></i>
                הורדת ${mediaType === 'video' ? 'וידאו' : 'שמע'}
              </button>`;
          }
        }
        function getActiveMediaType() {
            return activeMediaType;
        }

        function setActiveMediaTab(isVideo) {
            activeMediaType = isVideo ? 'video' : 'audio';
            $('#videoB')
                .toggleClass('active', !!isVideo)
                .attr('aria-expanded', !!isVideo ? 'true' : 'false')
                .attr('aria-selected', !!isVideo ? 'true' : 'false');
            $('#audioB')
                .toggleClass('active', !isVideo)
                .attr('aria-expanded', !isVideo ? 'true' : 'false')
                .attr('aria-selected', !isVideo ? 'true' : 'false');
        }

        async function getServiceWorkerMessageTarget() {
            if (!('serviceWorker' in navigator)) {
                return null;
            }

            if (navigator.serviceWorker.controller) {
                return navigator.serviceWorker.controller;
            }

            try {
                const registration = await navigator.serviceWorker.ready;
                return navigator.serviceWorker.controller || registration.active || null;
            } catch (error) {
                console.warn('[PWA] Service Worker registration is not ready.', error);
                return null;
            }
        }

        async function postServiceWorkerMessage(message) {
            try {
                const serviceWorker = await getServiceWorkerMessageTarget();
                if (!serviceWorker) {
                    console.warn('[PWA] Service Worker message target is not available.');
                    return false;
                }

                serviceWorker.postMessage(message);
                return true;
            } catch (error) {
                console.warn('[PWA] Failed to post Service Worker message.', error);
                return false;
            }
        }

        function toAbsoluteUrl(url, baseUrl) {
            return new URL(url, baseUrl || window.location.href).href;
        }

        function collectPlaylistUrls(playlistText, playlistUrl) {
            const urls = [];
            const uriAttributePattern = /\bURI="([^"]+)"/gi;
            const addUrl = (value) => {
                if (!value || value.startsWith('data:')) return;
                try {
                    const absoluteUrl = new URL(value, playlistUrl);
                    if (absoluteUrl.protocol !== 'http:' && absoluteUrl.protocol !== 'https:') return;
                    urls.push(absoluteUrl.href);
                } catch {
                }
            };

            playlistText.split('\n').forEach(rawLine => {
                const line = rawLine.trim();
                if (!line) return;

                if (line.startsWith('#')) {
                    uriAttributePattern.lastIndex = 0;
                    let match;
                    while ((match = uriAttributePattern.exec(line)) !== null) {
                        addUrl(match[1]);
                    }
                    return;
                }

                addUrl(line);
            });

            return urls;
        }

        function uniqueUrls(urls) {
            return [...new Set(urls.filter(Boolean))];
        }

        async function getPlaylistText(url) {
            const response = await fetch(url, { credentials: 'same-origin' });
            if (!response.ok) {
                throw new Error(`Playlist request failed: ${response.status}`);
            }

            return response.text();
        }

        function resolveQualityPlaylistUrl(masterContent, masterUrl, resolution) {
            const playlistFile = `${resolution.replace('p', '')}p.m3u8`;
            const playlistFileLower = `/${playlistFile.toLowerCase()}`;
            const playlistUrls = collectPlaylistUrls(masterContent, masterUrl);
            return playlistUrls.find(url => new URL(url).pathname.toLowerCase().endsWith(playlistFileLower))
                || toAbsoluteUrl(playlistFile, masterUrl);
        }

        async function buildHlsDownloadUrls(resolution) {
            const masterUrl = toAbsoluteUrl(lessonConfig.hlsMasterPlaylistUrl);
            const masterContent = await getPlaylistText(masterUrl);
            const playlistUrl = resolveQualityPlaylistUrl(masterContent, masterUrl, resolution);
            const playlistContent = await getPlaylistText(playlistUrl);
            const mediaUrls = collectPlaylistUrls(playlistContent, playlistUrl);

            return {
                playlistUrl,
                urls: uniqueUrls([masterUrl, playlistUrl, ...mediaUrls])
            };
        }

        async function handleDownloadClick() {
            const mediaType = getActiveMediaType();
            if (downloadStartInProgress.has(mediaType)) {
                return;
            }

            await refreshLocalData();
            if (getBlockingMedia(localData, mediaType)) {
                await updateDownloadUI();
                return;
            }

            if (mediaType === 'video') {
                let opts = '';
                ['1080', '720', '480', '360', '240'].forEach(q => {
                    if (lessonConfig.qualities['q' + q] !== -1) {
                        opts += `<button class="btn btn-primary btn-block my-2 resolution-choice-btn" data-resolution="${q}p">${q}p</button>`;
                    }
                });
                $('#resolution-options-container').html(opts);
                $('#resolutionModal').modal('show');
            } else {
                startAudioDownload();
            }
        }

        async function startVideoDownload(resolution) {
            $('#resolutionModal').modal('hide');
            const mediaType = 'video';
            if (downloadStartInProgress.has(mediaType)) {
                return;
            }

            setDownloadStartInProgress(mediaType, true);
            try {
                await updateDownloadUI();
                await refreshLocalData();
                if (getBlockingMedia(localData, mediaType)) {
                    setDownloadStartInProgress(mediaType, false);
                    await updateDownloadUI();
                    return;
                }

                const serviceWorker = await getServiceWorkerMessageTarget();
                if (!serviceWorker) {
                    throw new Error('Service Worker is unavailable.');
                }

                const { playlistUrl, urls } = await buildHlsDownloadUrls(resolution);
                const metadata = { ...lessonConfig.pwaMetaData, mediaType, resolution, hlsQualityPlaylistUrl: playlistUrl };
                await offlineVideoDB.startDownload(metadata, mediaType, resolution);
                serviceWorker.postMessage({ type: 'CACHE_MEDIA', payload: { urls, metadata } });
                setDownloadStartInProgress(mediaType, false);
                await updateDownloadUI();
            } catch (error) {
                console.error('Video download start failed:', error);
                setDownloadStartInProgress(mediaType, false);
                await offlineVideoDB.updateMediaStatus(lessonConfig.contentName, mediaType, 'none');
                await updateDownloadUI();
            } finally {
                setDownloadStartInProgress(mediaType, false);
            }
        }

        async function startAudioDownload() {
            const mediaType = 'audio';
            if (downloadStartInProgress.has(mediaType)) {
                return;
            }

            setDownloadStartInProgress(mediaType, true);
            try {
                await updateDownloadUI();
                await refreshLocalData();
                if (getBlockingMedia(localData, mediaType)) {
                    setDownloadStartInProgress(mediaType, false);
                    await updateDownloadUI();
                    return;
                }

                const serviceWorker = await getServiceWorkerMessageTarget();
                if (!serviceWorker) {
                    throw new Error('Service Worker is unavailable.');
                }

                const metadata = { ...lessonConfig.pwaMetaData, mediaType, resolution: null, audioUrl: lessonConfig.audioUrl };
                await offlineVideoDB.startDownload(metadata, mediaType, null);
                serviceWorker.postMessage({ type: 'CACHE_MEDIA', payload: { urls: [lessonConfig.audioUrl], metadata } });
                setDownloadStartInProgress(mediaType, false);
                await updateDownloadUI();
            } catch (error) {
                console.error('Audio download start failed:', error);
                setDownloadStartInProgress(mediaType, false);
                await offlineVideoDB.updateMediaStatus(lessonConfig.contentName, mediaType, 'none');
                await updateDownloadUI();
            } finally {
                setDownloadStartInProgress(mediaType, false);
            }
        }

        async function handleDeleteClick(mediaType) {
            if (!confirm(`האם למחוק את ${mediaType === 'video' ? 'הוידאו' : 'השמע'}?`)) {
                return;
            }

            const operationVersion = bumpMediaOperationVersion();
            const wasActiveMedia = mediaType === getActiveMediaType();
            const progressSnapshot = wasActiveMedia ? await persistCurrentProgress(false, true) : null;

            setPendingMediaDelete(mediaType, true);
            try {
                await offlineVideoDB.clearMedia(lessonConfig.contentName, mediaType);
                if (typeof offlineVideoDB.cleanupRemovedMedia === 'function') {
                    await offlineVideoDB.cleanupRemovedMedia([{ contentName: lessonConfig.contentName, mediaType }]);
                }

                await refreshLocalData();
                await updateDownloadUI();

                if (wasActiveMedia && isCurrentMediaOperation(operationVersion)) {
                    await rebuildPlayerAfterActiveMediaDelete(mediaType, progressSnapshot, operationVersion);
                }

                markLocalMediaDeleteHandled(mediaType);
                postServiceWorkerMessage({
                    type: 'DELETE_MEDIA_CACHE',
                    payload: { contentName: lessonConfig.contentName, mediaType }
                }).catch(error => console.warn('[PWA] Service Worker delete cleanup failed.', error));
            } catch (error) {
                console.warn('[PWA] Local media delete failed.', error);
                await refreshLocalData();
                await updateDownloadUI();
            } finally {
                setPendingMediaDelete(mediaType, false);
                await refreshLocalData();
                await updateDownloadUI();
            }
        }

        async function rebuildPlayerAfterActiveMediaDelete(deletedMediaType, progressSnapshot, operationVersion = mediaOperationVersion) {
            if (!isCurrentMediaOperation(operationVersion)) return;

            const isCurrentlyOffline = lessonConfig.isOffline || navigator.onLine === false;
            const videoAvailableOffline = localData?.videoStatus === 'completed';
            const audioAvailableOffline = localData?.audioStatus === 'completed';
            let playerWasLoaded = false;

            if (!isCurrentlyOffline && getActiveMediaType() !== deletedMediaType) {
                return;
            }

            clearPlayer();

            if (isCurrentlyOffline) {
                if (!isCurrentMediaOperation(operationVersion)) return;
                if (deletedMediaType === 'video' && audioAvailableOffline && lessonConfig.hasAudio) {
                    setActiveMediaTab(false);
                    initAudio();
                    playerWasLoaded = true;
                } else if (deletedMediaType === 'audio' && videoAvailableOffline && canAccessVideoPlayback()) {
                    setActiveMediaTab(true);
                    await initVideo();
                    playerWasLoaded = true;
                } else {
                    $('#player-wrapper').html('<div class="alert alert-warning text-center"><h3>אתה לא מחובר לאינטרנט</h3><p>המדיה נמחקה מהמכשיר ואינה זמינה ללא חיבור.</p></div>');
                    return;
                }
            } else if (deletedMediaType === 'video' && canAccessVideoPlayback()) {
                setActiveMediaTab(true);
                await initVideo();
                playerWasLoaded = true;
            } else if (deletedMediaType === 'audio' && lessonConfig.hasAudio) {
                setActiveMediaTab(false);
                initAudio();
                playerWasLoaded = true;
            }

            if (!isCurrentMediaOperation(operationVersion)) return;

            if (!playerWasLoaded) {
                ensurePlayerHasContent();
                return;
            }

            const reloadTime = normalizePlaybackTime(progressSnapshot?.time);
            if (reloadTime) {
                seekPlayerTo(reloadTime);
            } else {
                await seekToLastKnownTime();
            }

            if (player) {
                startLocalTimeUpdater();
            } else {
                ensurePlayerHasContent();
            }
        }

        function getAvailableDownloadedMediaType() {
            const activeMedia = getActiveMediaType();
            if (getMediaStatus(localData, activeMedia) === 'completed') {
                return activeMedia;
            }

            if (lessonConfig.hasAudio && getMediaStatus(localData, 'audio') === 'completed') {
                return 'audio';
            }

            if (canAccessVideoPlayback() && getMediaStatus(localData, 'video') === 'completed') {
                return 'video';
            }

            return null;
        }

        async function reloadActivePlayerFromCurrentState(reason) {
            console.log(`[Connectivity] Reloading active player. reason=${reason}`);
            const activeMedia = getActiveMediaType();
            const operationVersion = mediaOperationVersion;
            const shouldResumeFromMediaFailure = consumeMediaPlaybackResumeIntent();
            const shouldResume = isPlayerActivelyPlaying() || shouldResumeFromMediaFailure;
            const progressSnapshot = await persistCurrentProgress(false, true);

            if (!isCurrentMediaOperation(operationVersion)) return;

            let playerWasLoaded = false;
            clearPlayer();
            if (activeMedia === 'video' && canAccessVideoPlayback()) {
                await initVideo();
                playerWasLoaded = true;
            } else if (activeMedia === 'audio' && lessonConfig.hasAudio) {
                initAudio();
                playerWasLoaded = true;
            }

            if (!isCurrentMediaOperation(operationVersion)) return;

            if (!playerWasLoaded) {
                ensurePlayerHasContent();
                return;
            }

            const reloadTime = normalizePlaybackTime(progressSnapshot?.time);
            if (reloadTime) {
                seekPlayerTo(reloadTime);
            } else {
                await seekToLastKnownTime();
            }

            if (player) {
                startLocalTimeUpdater();
                if (shouldResume) {
                    const playResult = player.play();
                    if (playResult?.catch) {
                        playResult.catch(error => console.warn('[Connectivity] Resume after reload failed.', error));
                    }
                }
            } else {
                ensurePlayerHasContent();
            }
        }

        function clearConnectivityProbeTimer() {
            if (connectivityProbeTimer) {
                clearTimeout(connectivityProbeTimer);
                connectivityProbeTimer = null;
            }
        }

        function scheduleConnectivityProbe(delayMs = connectivityProbeIntervalMs, force = false) {
            clearConnectivityProbeTimer();
            connectivityProbeTimer = setTimeout(() => {
                connectivityProbeTimer = null;
                runConnectivityProbe(force).catch(error => console.warn('[Connectivity] Online probe failed.', error));
            }, delayMs);
        }

        async function probeOnlineStatus() {
            try {
                const response = await fetch(`/sw.js?onlineProbe=${Date.now()}`, {
                    cache: 'no-store',
                    credentials: 'same-origin'
                });
                return response.ok;
            } catch {
                return false;
            }
        }

        async function runConnectivityProbe(force = false) {
            if (connectivityProbeInFlight) return;
            if (!force && !lessonConfig.isOffline && navigator.onLine !== false) return;

            connectivityProbeInFlight = true;
            try {
                const isOnline = await probeOnlineStatus();
                if (isOnline) {
                    failedForcedConnectivityProbes = 0;
                    await handleConnectivityChange('probe-online', true);
                    return;
                }
            } finally {
                connectivityProbeInFlight = false;
            }

            if (force && !lessonConfig.isOffline && navigator.onLine !== false) {
                failedForcedConnectivityProbes += 1;
                if (failedForcedConnectivityProbes >= forcedConnectivityFailureThreshold) {
                    failedForcedConnectivityProbes = 0;
                    await handleConnectivityChange('probe-offline', false);
                    return;
                }

                scheduleConnectivityProbe(forcedConnectivityRetryMs, true);
                return;
            }

            if (lessonConfig.isOffline || navigator.onLine === false) {
                failedForcedConnectivityProbes = 0;
                scheduleConnectivityProbe();
            }
        }

        async function handleConnectivityChange(reason, isOnlineOverride = null) {
            if (connectivityChangeInProgress) {
                const shouldForceRetry = isOnlineOverride === false ||
                    (typeof reason === 'string' && reason.startsWith('media-'));
                scheduleConnectivityProbe(1000, shouldForceRetry);
                return;
            }
            connectivityChangeInProgress = true;

            const isNowOffline = isOnlineOverride === null ? !navigator.onLine : !isOnlineOverride;
            const wasOffline = lessonConfig.isOffline;
            lessonConfig.isOffline = isNowOffline;

            try {
                if (isNowOffline) {
                    scheduleConnectivityProbe();
                } else {
                    clearConnectivityProbeTimer();
                }

                await refreshLocalData();

                if (!isNowOffline) {
                    $('#download-container').show();
                }

                if (offlineMediaPlaybackEnabled) {
                    resendOfflineMediaPlaybackState();
                }

                if (!isNowOffline && wasOffline) {
                    await reloadActivePlayerFromCurrentState(reason);
                    await updateDownloadUI();
                    return;
                }

                const downloadedMediaType = getAvailableDownloadedMediaType();
                if (isNowOffline && downloadedMediaType) {
                    const previousMediaType = getActiveMediaType();
                    if (downloadedMediaType !== previousMediaType) {
                        setActiveMediaTab(downloadedMediaType === 'video');
                    }
                    if (!offlineMediaPlaybackEnabled || downloadedMediaType !== previousMediaType) {
                        await reloadActivePlayerFromCurrentState(reason);
                    }
                }

                await updateDownloadUI();
            } finally {
                connectivityChangeInProgress = false;
            }
        }

        function normalizePlaybackTime(value) {
            const seconds = Number(value);
            return Number.isFinite(seconds) && seconds > 0 ? seconds : 0;
        }

        function getStoredProgress() {
            const keys = progressStorageKey === legacyProgressStorageKey
                ? [progressStorageKey]
                : [progressStorageKey, legacyProgressStorageKey].filter(Boolean);

            for (const key of keys) {
                try {
                    const raw = localStorage.getItem(key);
                    if (!raw) continue;
                    const parsed = JSON.parse(raw);
                    const time = normalizePlaybackTime(parsed?.time);
                    if (!time) continue;
                    return { time, isVideo: !!parsed.isVideo, updatedAt: parsed.updatedAt || 0, source: 'localStorage' };
                } catch {
                }
            }

            return null;
        }

        function clearLegacyStoredProgress() {
            if (!legacyProgressStorageKey || legacyProgressStorageKey === progressStorageKey) return;

            try {
                localStorage.removeItem(legacyProgressStorageKey);
            } catch {
            }
        }

        function getStoredMediaPreference() {
            const keys = mediaPreferenceStorageKey === legacyMediaPreferenceStorageKey
                ? [mediaPreferenceStorageKey]
                : [mediaPreferenceStorageKey, legacyMediaPreferenceStorageKey].filter(Boolean);

            for (const key of keys) {
                try {
                    const raw = localStorage.getItem(key);
                    if (!raw) continue;
                    const parsed = JSON.parse(raw);
                    if (parsed?.isVideo === undefined || parsed?.isVideo === null) continue;
                    return { isVideo: !!parsed.isVideo, updatedAt: parsed.updatedAt || 0, source: 'localStoragePreference' };
                } catch {
                }
            }

            return null;
        }

        function clearLegacyStoredMediaPreference() {
            if (!legacyMediaPreferenceStorageKey || legacyMediaPreferenceStorageKey === mediaPreferenceStorageKey) return;

            try {
                localStorage.removeItem(legacyMediaPreferenceStorageKey);
            } catch {
            }
        }

        function saveMediaPreference(isVideo, force = false, updatedAt = Date.now()) {
            const normalizedIsVideo = !!isVideo;
            const existingPreference = getStoredMediaPreference();
            const existingProgress = getStoredProgress();
            if (!force && existingPreference && existingPreference.isVideo === normalizedIsVideo) {
                return { ...existingPreference, changed: false };
            }

            const preference = {
                isVideo: normalizedIsVideo,
                updatedAt: Math.trunc(updatedAt || Date.now())
            };

            try {
                localStorage.setItem(mediaPreferenceStorageKey, JSON.stringify(preference));
                clearLegacyStoredMediaPreference();
            } catch (error) {
                console.warn('[Timekeeping] Local media preference save failed.', error);
            }

            const existingTime = normalizePlaybackTime(localData?.lastPlayed?.time) || normalizePlaybackTime(existingProgress?.time);
            if (existingTime) {
                try {
                    localStorage.setItem(progressStorageKey, JSON.stringify({
                        time: existingTime,
                        isVideo: normalizedIsVideo,
                        updatedAt: preference.updatedAt,
                        source: 'localStorage'
                    }));
                    clearLegacyStoredProgress();
                } catch (error) {
                    console.warn('[Timekeeping] Local progress media preference update failed.', error);
                }
            }

            if (localData) {
                localData.lastPlayed = {
                    ...(localData.lastPlayed || {}),
                    time: existingTime,
                    isVideo: normalizedIsVideo,
                    updatedAt: preference.updatedAt
                };
            }

            return { ...preference, changed: true, source: 'localStoragePreference' };
        }

        function saveStoredProgress(time, isVideo, force = false) {
            const normalizedTime = normalizePlaybackTime(time);
            if (!normalizedTime) return null;

            const existingProgress = getStoredProgress();
            if (!force && existingProgress && !hasMeaningfulProgressChange(existingProgress, normalizedTime, isVideo)) {
                return { ...existingProgress, changed: false };
            }

            const progress = {
                time: normalizedTime,
                isVideo: !!isVideo,
                updatedAt: Date.now(),
                source: 'localStorage'
            };

            try {
                localStorage.setItem(progressStorageKey, JSON.stringify(progress));
                clearLegacyStoredProgress();
            } catch (error) {
                console.warn('[Timekeeping] Local progress save failed.', error);
            }

            return { ...progress, changed: true };
        }

        function addMediaPreferenceCandidate(candidates, candidate) {
            if (!candidate) return;
            if (candidate.isVideo && !canAccessVideoPlayback()) return;
            if (!candidate.isVideo && !lessonConfig.hasAudio) return;
            candidates.push(candidate);
        }

        function getLastKnownMediaPreference() {
            const candidates = [];

            const indexedPreference = localData?.lastPlayed;
            if (indexedPreference?.isVideo !== undefined && indexedPreference?.isVideo !== null) {
                addMediaPreferenceCandidate(candidates, {
                    isVideo: !!indexedPreference.isVideo,
                    updatedAt: indexedPreference.updatedAt || 0,
                    source: 'indexedDBPreference'
                });
            }

            const storedProgress = getStoredProgress();
            if (storedProgress) {
                addMediaPreferenceCandidate(candidates, {
                    isVideo: storedProgress.isVideo,
                    updatedAt: storedProgress.updatedAt || 0,
                    source: storedProgress.source
                });
            }

            addMediaPreferenceCandidate(candidates, getStoredMediaPreference());

            if (lessonConfig.serverIsVideo !== null && lessonConfig.serverIsVideo !== undefined) {
                addMediaPreferenceCandidate(candidates, {
                    isVideo: !!lessonConfig.serverIsVideo,
                    updatedAt: lessonConfig.serverUpdatedAt || 0,
                    source: 'serverPreference'
                });
            }

            candidates.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
            return candidates[0] || null;
        }

        function getLastKnownProgress() {
            const candidates = [];
            const indexedTime = normalizePlaybackTime(localData?.lastPlayed?.time);
            if (indexedTime) {
                addProgressCandidate(candidates, {
                    time: indexedTime,
                    isVideo: !!localData.lastPlayed.isVideo,
                    updatedAt: localData.lastPlayed.updatedAt || 0,
                    source: 'indexedDB'
                });
            }

            const storedProgress = getStoredProgress();
            if (storedProgress) addProgressCandidate(candidates, storedProgress);

            const serverTime = normalizePlaybackTime(lessonConfig.serverTime);
            if (serverTime) {
                addProgressCandidate(candidates, {
                    time: serverTime,
                    isVideo: lessonConfig.serverIsVideo ?? true,
                    updatedAt: lessonConfig.serverUpdatedAt || 0,
                    source: 'server'
                });
            }

            candidates.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
            return candidates[0] || null;
        }

        function sendProgressToServer(time, isVideo, updatedAt = Date.now()) {
            const form = document.getElementById('hiddenTimeForm');
            if (!form || time === undefined || time === null || time === '') return;

            const normalizedTime = normalizePlaybackTime(time);

            const formData = new FormData(form);
            formData.set('time', normalizedTime.toString());
            formData.set('isVideo', (!!isVideo).toString());
            formData.set('clientUpdatedAt', Math.trunc(updatedAt || Date.now()).toString());

            try {
                if (navigator.sendBeacon?.(form.getAttribute('action'), formData)) {
                    return;
                }
            } catch (error) {
                console.warn('[Timekeeping] sendBeacon progress save failed.', error);
            }

            fetch(form.getAttribute('action'), {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                keepalive: true
            }).catch(error => console.warn('[Timekeeping] Server progress save failed.', error));
        }

        function syncProgressCandidateToServer(candidate) {
            if (!candidate || candidate.source === 'server') return false;

            sendProgressToServer(candidate.time, candidate.isVideo, candidate.updatedAt);
            if (pendingServerProgress && (pendingServerProgress.updatedAt || 0) <= (candidate.updatedAt || 0) + 1000) {
                pendingServerProgress = null;
            }

            return true;
        }

        async function persistCurrentProgress(syncServer = false, force = false) {
            if (!player) return null;

            const time = normalizePlaybackTime(player.currentTime);
            if (!time) return null;

            const isVideo = getActiveMediaType() === 'video';
            const latestBeforeSave = getLastKnownProgress();
            const latestIsNewerThanThisPage = (latestBeforeSave?.updatedAt || 0) > pageLoadedAt + 1000;
            const activeOrRecent = isPlayerActivelyPlaying() || hasRecentPlaybackActivity();
            const materialChange = hasMeaningfulProgressChange(latestBeforeSave, time, isVideo);

            if (!force) {
                if (latestIsNewerThanThisPage && !activeOrRecent) {
                    if (syncServer) syncProgressCandidateToServer(latestBeforeSave);
                    return latestBeforeSave;
                }
                if (!activeOrRecent && !materialChange) {
                    if (syncServer) syncProgressCandidateToServer(pendingServerProgress || latestBeforeSave);
                    if (!pendingServerProgress) return latestBeforeSave;
                }
            }

            const progress = saveStoredProgress(time, isVideo, force);
            if (!progress) return null;

            if (progress.changed) {
                pendingServerProgress = progress;
            }

            if (localData && progress.changed) {
                localData.lastPlayed = progress;
            }

            const hasDownloadedMedia = localData?.videoStatus === 'completed' || localData?.audioStatus === 'completed';
            if (progress.changed && (lessonConfig.isOffline || hasDownloadedMedia)) {
                offlineVideoDB.saveTimestamp(lessonConfig.contentName, time, isVideo)
                    .catch(error => console.warn('[Timekeeping] IndexedDB progress save failed.', error));
            }

            if (syncServer && lessonConfig.isMember && !lessonConfig.isOffline) {
                const progressToSync = (progress.changed || force || materialChange) ? progress : pendingServerProgress;
                syncProgressCandidateToServer(progressToSync);
            }

            return progress;
        }

        function seekPlayerTo(time) {
            const normalizedTime = normalizePlaybackTime(time);
            if (!player || !normalizedTime) return;
            if (lessonConfig.hasExternalVideo) {
                player.once('ready', () => player.embed.seekTo(normalizedTime, true));
                return;
            }

            const media = player.media || document.querySelector('#player, #playerA');
            let applied = false;
            let retryTimer = null;
            let attempts = 0;
            const seekEvents = ['loadedmetadata', 'durationchange', 'loadeddata', 'canplay'];

            const cleanup = () => {
                if (retryTimer) {
                    clearTimeout(retryTimer);
                    retryTimer = null;
                }
                if (media) {
                    seekEvents.forEach(eventName => media.removeEventListener(eventName, applySeek));
                }
            };

            const scheduleRetry = () => {
                if (retryTimer || applied || attempts >= 6) return;
                retryTimer = setTimeout(() => {
                    retryTimer = null;
                    applySeek();
                }, 500);
            };

            const hasMetadata = () => {
                if (!media) return true;
                return media.readyState >= 1 || Number.isFinite(media.duration);
            };

            const applySeek = () => {
                if (applied || !player) return;
                attempts += 1;

                if (!hasMetadata()) {
                    scheduleRetry();
                    return;
                }

                try {
                    player.currentTime = normalizedTime;
                    applied = true;
                    cleanup();
                } catch (error) {
                    if (attempts < 6) {
                        scheduleRetry();
                    } else {
                        cleanup();
                        console.warn('[Timekeeping] Initial seek failed.', error);
                    }
                }
            };

            if (media) {
                seekEvents.forEach(eventName => media.addEventListener(eventName, applySeek));

                if (media.readyState >= 1 || Number.isFinite(media.duration)) {
                    applySeek();
                } else {
                    try {
                        if (media.tagName === 'AUDIO' && media.preload !== 'metadata') {
                            media.preload = 'metadata';
                        }
                        if (media.tagName === 'AUDIO' && media.readyState === 0) {
                            media.load();
                        }
                    } catch (error) {
                        console.warn('[Timekeeping] Metadata load request failed.', error);
                    }
                    scheduleRetry();
                }
            } else {
                player.once('ready', applySeek);
            }
        }

        async function seekToLastKnownTime() {
            const progress = getLastKnownProgress();
            if (progress?.time) {
                console.log(`[Timekeeping] Seeking to ${progress.time}s from ${progress.source}.`);
                seekPlayerTo(progress.time);
            }
        }

        function startLocalTimeUpdater() {
            if (localTimeUpdater) clearInterval(localTimeUpdater);
            attachProgressActivityListeners();
            localTimeUpdater = setInterval(() => {
                persistCurrentProgress(false);
            }, 5000);
        }

        function flushCurrentProgress(stopUpdater = true) {
            if (stopUpdater && localTimeUpdater) {
                clearInterval(localTimeUpdater);
                localTimeUpdater = null;
            }
            persistCurrentProgress(true);
        }

        async function syncLocalTimeToServerOnLoad() {
            if (!lessonConfig.isMember || lessonConfig.isOffline) return;

            const progress = getLastKnownProgress();
            if (!progress) {
                const mediaPreference = getLastKnownMediaPreference();
                if (mediaPreference && mediaPreference.source !== 'serverPreference') {
                    sendProgressToServer(0, mediaPreference.isVideo, mediaPreference.updatedAt);
                }
                return;
            }

            const serverUpdatedAt = lessonConfig.serverUpdatedAt || 0;
            const mediaPreference = getLastKnownMediaPreference();
            const preferenceIsNewerThanServer =
                mediaPreference &&
                mediaPreference.source !== 'serverPreference' &&
                (mediaPreference.updatedAt || 0) > serverUpdatedAt + 1000;

            if (progress.source === 'server') {
                if (preferenceIsNewerThanServer) {
                    sendProgressToServer(progress.time, mediaPreference.isVideo, mediaPreference.updatedAt);
                }
                return;
            }

            if (serverUpdatedAt && (progress.updatedAt || 0) + 1000 < serverUpdatedAt) return;

            sendProgressToServer(progress.time, progress.isVideo, progress.updatedAt);
        }

        async function initializeFirstPlayer() {
            console.log('[Init] Starting initial player load...');
            let initialTabIsVideo = lessonConfig.isVideoSelected;
            const mediaPreference = getLastKnownMediaPreference();
            if (mediaPreference) {
                initialTabIsVideo = mediaPreference.isVideo && canAccessVideoPlayback();
            }
            if (!initialTabIsVideo && !lessonConfig.hasAudio && canAccessVideoPlayback()) {
                initialTabIsVideo = true;
            }

            if (lessonConfig.isOffline) {
                const videoAvailable = localData?.videoStatus === 'completed';
                const audioAvailable = localData?.audioStatus === 'completed';
                if (!videoAvailable && !audioAvailable) {
                    $('#player-wrapper').html('<div class="alert alert-warning text-center"><h3>אתה לא מחובר לאינטרנט</h3><p>השיעור הזה לא הורד למכשיר.</p></div>');
                    $('#download-container').hide();
                    return;
                }
                initialTabIsVideo = (initialTabIsVideo && videoAvailable) || !audioAvailable;
            }

            if (initialTabIsVideo && canAccessVideoPlayback()) {
                setActiveMediaTab(true);
                await initVideo();
            } else if (lessonConfig.hasAudio) {
                setActiveMediaTab(false);
                initAudio();
            } else {
                console.log('[Init] No media available to load.');
                return;
            }

            ensurePlayerHasContent();
            await seekToLastKnownTime();
            startLocalTimeUpdater();
            await updateDownloadUI();
        }

        document.addEventListener('DOMContentLoaded', async () => {
            try {
                console.log('[Init] DOM content loaded.');
                await refreshLocalData();
                await syncLocalTimeToServerOnLoad();

                $('a[data-toggle="tab"]').on('show.bs.tab', function (e) {
                    const targetId = $(e.target).attr('id');
                    if (targetId !== 'videoB' && targetId !== 'audioB') return;

                    const targetIsVideo = targetId === 'videoB';
                    bumpMediaOperationVersion();
                    transitionTime = normalizePlaybackTime(player?.currentTime);
                    if (transitionTime) {
                        persistCurrentProgress(false, true)
                            .catch(error => console.warn('[Timekeeping] Tab switch progress save failed.', error));
                    }
                    setActiveMediaTab(targetIsVideo);
                    updateDownloadUI().catch(error => console.warn('[PWA] Tab switch download UI update failed.', error));
                });

                $('a[data-toggle="tab"]').on('shown.bs.tab', async function (e) {
                    const targetId = $(e.target).attr('id');
                    if (targetId !== 'videoB' && targetId !== 'audioB') return;

                    const operationVersion = mediaOperationVersion;
                    const capturedTransitionTime = normalizePlaybackTime(transitionTime);
                    const targetIsVideo = targetId === 'videoB';
                    setActiveMediaTab(targetIsVideo);
                    const mediaPreference = saveMediaPreference(targetIsVideo, true);
                    if (lessonConfig.isMember && !lessonConfig.isOffline) {
                        const lastKnownTime = normalizePlaybackTime(getLastKnownProgress()?.time);
                        sendProgressToServer(capturedTransitionTime || lastKnownTime || 0, targetIsVideo, mediaPreference.updatedAt);
                    }
                    console.log(`[Event] User switched tab to: ${targetId}, captured time: ${capturedTransitionTime}`);
                    await updateDownloadUI();
                    if (!isCurrentMediaOperation(operationVersion)) return;

                    let playerWasLoaded = false;
                    clearPlayer();
                    if (targetId === 'videoB' && lessonConfig.hasAnyVideo) {
                        await initVideo();
                        playerWasLoaded = true;
                    } else if (targetId === 'audioB' && lessonConfig.hasAudio) {
                        initAudio();
                        playerWasLoaded = true;
                    }

                    if (!isCurrentMediaOperation(operationVersion)) return;
                    if (!playerWasLoaded) {
                        ensurePlayerHasContent();
                        return;
                    }

                    if (capturedTransitionTime > 0) { seekPlayerTo(capturedTransitionTime); transitionTime = 0; }
                    else { await seekToLastKnownTime(); }
                    if (player) startLocalTimeUpdater();
                    else ensurePlayerHasContent();
                    await updateDownloadUI();
                });

                $(document).on('click', '#downloadBtn', handleDownloadClick);
                $(document).on('click', '#cancelDownloadBtn', () => {
                    postServiceWorkerMessage({
                        type: 'CANCEL_DOWNLOAD',
                        payload: { contentName: lessonConfig.contentName, mediaType: getActiveMediaType() }
                    });
                });
                $(document).on('click', '.delete-media-btn', function() { handleDeleteClick($(this).data('media-type')); });
                $(document).on('click', '.resolution-choice-btn', function() { startVideoDownload($(this).data('resolution')); });
                await initializeFirstPlayer();
            } catch (error) { console.error("A critical error occurred during page initialization:", error); $('#player-wrapper').html('<div class="alert alert-danger">אירעה שגיאה חמורה בטעינת הדף. נסה לרענן.</div>'); }
        });


        function isDuplicateDownloadMessage(data) {
            if (!data?.messageId) return false;
            if (handledDownloadMessageIds.includes(data.messageId)) return true;
            handledDownloadMessageIds.push(data.messageId);
            if (handledDownloadMessageIds.length > 50) handledDownloadMessageIds.shift();
            return false;
        }

        async function handleDownloadMessage(data) {
            if (isDuplicateDownloadMessage(data)) return;

            const { type, payload } = data || {};
            if (!payload || payload.contentName !== lessonConfig.contentName) return;

            if (type === 'DOWNLOAD_PROGRESS') {
                if (payload.mediaType !== getActiveMediaType()) return;
                const pb = document.getElementById('progress-bar');
                if (pb) { pb.style.width = payload.progress + '%'; pb.textContent = payload.progress + '%'; }
            } else if (['DOWNLOAD_COMPLETE', 'DOWNLOAD_FAILED', 'DOWNLOAD_CANCELLED', 'DELETE_MEDIA_CACHE_COMPLETE', 'DELETE_MEDIA_CACHE_FAILED'].includes(type)) {
                const currentMediaType = getActiveMediaType();
                const operationVersion = mediaOperationVersion;
                const shouldReloadActivePlayer = type === 'DOWNLOAD_COMPLETE'
                    && payload.mediaType === currentMediaType
                    && (lessonConfig.isOffline || offlineMediaPlaybackEnabled);
                const deleteWasHandledLocally = type === 'DELETE_MEDIA_CACHE_COMPLETE'
                    && consumeLocalMediaDeleteHandled(payload.mediaType);
                const shouldRebuildAfterDelete = type === 'DELETE_MEDIA_CACHE_COMPLETE'
                    && payload.mediaType === currentMediaType
                    && !deleteWasHandledLocally;
                const reloadProgress = (shouldReloadActivePlayer || shouldRebuildAfterDelete) ? await persistCurrentProgress(false, true) : null;
                await refreshLocalData();
                await updateDownloadUI();
                if (!isCurrentMediaOperation(operationVersion)) return;

                if (shouldRebuildAfterDelete) {
                    console.log(`[Broadcast] Player rebuild triggered by ${currentMediaType} cache delete.`);
                    await rebuildPlayerAfterActiveMediaDelete(payload.mediaType, reloadProgress, operationVersion);
                } else if (shouldReloadActivePlayer) {
                    console.log(`[Broadcast] Player reload triggered by ${currentMediaType} download completion.`);
                    let playerWasLoaded = false;
                    clearPlayer();
                    if (payload.mediaType === 'video') {
                        await initVideo();
                        playerWasLoaded = true;
                    } else {
                        initAudio();
                        playerWasLoaded = true;
                    }
                    if (!isCurrentMediaOperation(operationVersion)) return;
                    if (!playerWasLoaded) {
                        ensurePlayerHasContent();
                        return;
                    }
                    const reloadTime = normalizePlaybackTime(reloadProgress?.time);
                    if (reloadTime) {
                        seekPlayerTo(reloadTime);
                    } else {
                        await seekToLastKnownTime();
                    }
                    if (player) startLocalTimeUpdater();
                    else ensurePlayerHasContent();
                }
            }
        }

        if (broadcast) {
            broadcast.onmessage = (event) => { handleDownloadMessage(event.data); };
        }

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.addEventListener('message', (event) => { handleDownloadMessage(event.data); });
            navigator.serviceWorker.addEventListener('controllerchange', resendOfflineMediaPlaybackState);
        }

        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'hidden') {
                flushCurrentProgress(false);
            } else {
                if (!localTimeUpdater && player) {
                    startLocalTimeUpdater();
                }
                if (lessonConfig.isOffline || navigator.onLine === false) {
                    scheduleConnectivityProbe(500);
                } else {
                    scheduleConnectivityProbe(500, true);
                }
            }
        });
        window.addEventListener('pageshow', () => {
            resendOfflineMediaPlaybackState();
            if (lessonConfig.isOffline || navigator.onLine === false) {
                scheduleConnectivityProbe(500);
            } else {
                scheduleConnectivityProbe(500, true);
            }
        });
        window.addEventListener('offline', () => {
            handleConnectivityChange('offline', false).catch(error => console.warn('[Connectivity] Offline transition failed.', error));
        });
        window.addEventListener('online', () => {
            scheduleConnectivityProbe(0, true);
        });
        if (lessonConfig.isOffline || navigator.onLine === false) {
            scheduleConnectivityProbe(1000);
        }
        window.addEventListener('pagehide', () => {
            clearConnectivityProbeTimer();
            clearDownloadStatusRefresh();
            if (offlineMediaPlaybackEnabled) {
                postOfflineMediaState('DISABLE_OFFLINE_MEDIA');
            }
            flushCurrentProgress(true);
        });
        window.addEventListener('beforeunload', () => flushCurrentProgress(true));
    </script>
