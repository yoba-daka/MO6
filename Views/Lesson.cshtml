        function attachAudioRecovery(audioElement, getSourceUrl) {
            if (!audioElement) return null;

            let waitingTimer = null;
            let watchdogTimer = null;
            let lastTime = 0;
            let stagnantChecks = 0;
            let recovering = false;
            let retries = 0;
            let retryWindowStartedAt = Date.now();

            const clearWaitingTimer = () => {
                if (waitingTimer) {
                    clearTimeout(waitingTimer);
                    waitingTimer = null;
                }
            };

            const resetProgressState = () => {
                clearWaitingTimer();
                stagnantChecks = 0;
                lastTime = audioElement.currentTime || 0;
            };

            const attemptRecovery = reason => {
                if (recovering || audioElement.ended) return;

                const now = Date.now();
                if (now - retryWindowStartedAt > 30000) {
                    retries = 0;
                    retryWindowStartedAt = now;
                }

                if (retries >= 3) {
                    console.warn(`[Audio] Recovery limit reached. reason=${reason}`);
                    return;
                }

                const sourceUrl = (getSourceUrl && getSourceUrl(true)) || audioElement.currentSrc || audioElement.src;
                if (!sourceUrl) return;

                recovering = true;
                retries += 1;
                clearWaitingTimer();
                const currentTime = normalizePlaybackTime(audioElement.currentTime);
                const resumeTime = normalizePlaybackTime(lastTime) > currentTime + 1 ? normalizePlaybackTime(lastTime) : currentTime;
                const shouldResume = !audioElement.paused && !audioElement.ended;
                let restored = false;
                let recoveryTimeout = null;

                console.warn(`[Audio] Attempting recovery. reason=${reason}, retry=${retries}, time=${resumeTime}`);

                const cleanupRecoveryListeners = () => {
                    if (recoveryTimeout) {
                        clearTimeout(recoveryTimeout);
                        recoveryTimeout = null;
                    }
                    audioElement.removeEventListener('loadedmetadata', finishRecovery);
                    audioElement.removeEventListener('canplay', finishRecovery);
                    audioElement.removeEventListener('error', failRecovery);
                };

                const finishRecovery = async () => {
                    if (restored) return;
                    restored = true;
                    cleanupRecoveryListeners();

                    try {
                        if (resumeTime > 0) {
                            audioElement.currentTime = resumeTime;
                        }
                    } catch (error) {
                        console.warn('[Audio] Recovery seek failed.', error);
                    }

                    if (shouldResume) {
                        try {
                            await audioElement.play();
                        } catch (playError) {
                            console.warn('[Audio] Recovery play() failed.', playError);
                        }
                    }

                    resetProgressState();
                    recovering = false;
                };

                const failRecovery = () => {
                    cleanupRecoveryListeners();
                    recovering = false;
                };

                try {
                    audioElement.addEventListener('loadedmetadata', finishRecovery, { once: true });
                    audioElement.addEventListener('canplay', finishRecovery, { once: true });
                    audioElement.addEventListener('error', failRecovery, { once: true });

                    audioElement.pause();
                    const sourceNode = audioElement.querySelector('source');
                    if (sourceNode) {
                        sourceNode.src = sourceUrl;
                    }
                    audioElement.src = sourceUrl;
                    audioElement.load();

                    recoveryTimeout = setTimeout(finishRecovery, 5000);
                } catch (error) {
                    console.error('[Audio] Recovery failed.', error);
                    failRecovery();
                }
            };

            const scheduleRecovery = (reason, delayMs = 4000) => {
                clearWaitingTimer();
                waitingTimer = setTimeout(() => {
                    if (!audioElement.paused && !audioElement.ended && audioElement.readyState < 3) {
                        attemptRecovery(reason);
                    }
                }, delayMs);
            };

            const handleWaiting = () => scheduleRecovery('waiting-timeout');
            const handleStalled = () => scheduleRecovery('stalled-event');
            const handleError = () => attemptRecovery('error-event');
            const handleTimeUpdate = () => {
                markPlaybackActivity();
                lastTime = audioElement.currentTime || 0;
                stagnantChecks = 0;
                clearWaitingTimer();
            };

            const handleWatchdog = () => {
                if (audioElement.paused || audioElement.ended || recovering || audioElement.seeking || audioElement.readyState < 2) {
                    stagnantChecks = 0;
                    lastTime = audioElement.currentTime || 0;
                    return;
                }

                const currentTime = audioElement.currentTime || 0;
                if (Math.abs(currentTime - lastTime) < 0.05) {
                    stagnantChecks += 1;
                    if (stagnantChecks >= 3) {
                        attemptRecovery('watchdog-stalled');
                    }
                } else {
                    stagnantChecks = 0;
                    lastTime = currentTime;
                }
            };

            audioElement.addEventListener('waiting', handleWaiting);
            audioElement.addEventListener('stalled', handleStalled);
            audioElement.addEventListener('error', handleError);
            audioElement.addEventListener('canplay', resetProgressState);
            audioElement.addEventListener('playing', resetProgressState);
            audioElement.addEventListener('seeked', resetProgressState);
            audioElement.addEventListener('timeupdate', handleTimeUpdate);

            watchdogTimer = setInterval(handleWatchdog, 3000);
            resetProgressState();

            return () => {
                clearWaitingTimer();
                if (watchdogTimer) {
                    clearInterval(watchdogTimer);
                    watchdogTimer = null;
                }
                audioElement.removeEventListener('waiting', handleWaiting);
                audioElement.removeEventListener('stalled', handleStalled);
                audioElement.removeEventListener('error', handleError);
                audioElement.removeEventListener('canplay', resetProgressState);
                audioElement.removeEventListener('playing', resetProgressState);
                audioElement.removeEventListener('seeked', resetProgressState);
                audioElement.removeEventListener('timeupdate', handleTimeUpdate);
            };
        }

