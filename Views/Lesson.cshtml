                    else window.deferredPrompt = null;
                  }
                });
              }
            }
            hideStatus();
            return;
          }

          // 4) In PWA (or captured) → show proper download UI based on local state
          await refreshLocalData();

          const mediaType = getActiveMediaType();
          const mediaStatus = getMediaStatus(localData, mediaType);
          const blockingMedia = getBlockingMedia(localData, mediaType);
          const isStartingDownload = downloadStartInProgress.has(mediaType);

          hideStatus();
          container.innerHTML = '';

          if (isStartingDownload) {
            container.innerHTML = `
              <button class="btn btn-secondary btn-round d-inline-flex align-items-center" disabled style="gap:.4rem;">
                <i class="fa fa-spinner fa-spin" aria-hidden="true"></i>
