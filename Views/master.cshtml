    @* Image handling with fallback to logo *@
    @{
        string ogImage = "";
        string domain = Configuration["CustomDomain"];

        if (Model.Url() != "/" && (Model.HasValue("Image") && Model.Value("Image") is ImageCropperValue))
        {
            // GetCropUrl returns relative URL, so prepend domain
            var relativeImageUrl = Url.GetOptimizedCropUrl(Model.Value<ImageCropperValue>("Image"), "small");

            ogImage = domain + relativeImageUrl;
        }
        else
        {
            // Fallback to logo
            ogImage = domain + "/images/logo.webp";
        }
    }

    <meta property="og:image" content="@ogImage" />
