    <script>
        // --- Global PWA Flags and Install Logic ---
        let deferredPrompt;
        window.deferredPrompt = null;
        window.setDeferredPrompt = function (prompt) {
          deferredPrompt = prompt;
          window.deferredPrompt = prompt;
        };

        const isPWA = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
        let hasPWA = false;

        (async () => {
          if ('getInstalledRelatedApps' in navigator) {
            try {
              const currentAppId = new URL('/', window.location.origin).href;
              const apps = await navigator.getInstalledRelatedApps();
              hasPWA = apps.some(a => {
                if (a.platform !== 'webapp' || !a.id) return false;

                try {
                  return new URL(a.id, window.location.origin).href === currentAppId;
                } catch {
                  return a.id === currentAppId;
                }
              });
            } catch {}
          }
        })();

        const isPC = (() => {
          if (navigator.userAgentData && 'mobile' in navigator.userAgentData) {
            return !navigator.userAgentData.mobile;
          }
          return !/Android|iPhone|iPad|iPod|Mobi|Mobile|Windows Phone|BlackBerry|Opera Mini/i.test(navigator.userAgent);
        })();

        const isIOS = () => {
          const ua = navigator.userAgent || '';
          const iDevice = /iPad|iPhone|iPod/.test(ua);
          const iPadOS = !iDevice && navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1;
          return iDevice || iPadOS;
        };

        window.addEventListener('DOMContentLoaded', () => {
          const appBtn = document.getElementById('our-app');
          const mainAppDiv = document.getElementById('main-app'); // The content area of your modal

          if (appBtn) {
            if (isPWA) {
              appBtn.style.display = 'none';
            } else {
              appBtn.style.display = 'inline-block';
            }
          }

          if (isIOS()) {
            if (mainAppDiv) {
              renderIOSInstallUI(mainAppDiv);
            }
          } else if (isPC) {
            const installPwaBtn = document.getElementById('install-pwa-btn');
            if (installPwaBtn) {
              installPwaBtn.textContent = 'להתקנה במחשב';
            }
          }
        });

        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          window.setDeferredPrompt(e);
        });

        let installing = false;

        function dismissInstallModal() {
          const el = document.getElementById('appInstallModal');
          if (!el) return;

          if (window.bootstrap && typeof bootstrap.Modal === 'function') {
            let instance = bootstrap.Modal.getInstance(el);
            if (!instance) instance = new bootstrap.Modal(el);
            instance.hide();
            return;
          }
          const $jq = window.jQuery || window.$;
          if ($jq && typeof $jq.fn?.modal === 'function') {
            $jq(el).modal('hide');
            return;
          }
          el.classList.remove('show');
          el.setAttribute('aria-hidden', 'true');
          el.style.display = 'none';
          const backdrop = document.querySelector('.modal-backdrop');
          if (backdrop) backdrop.parentNode.removeChild(backdrop);
          document.body.classList.remove('modal-open');
          document.body.style.paddingRight = '';
        }

        function renderInstallingUI(container) {
          container.innerHTML = `
            <div class="text-center" style="max-width:520px;margin:24px auto;padding:0 16px;">
              <div class="mt-3 mb-2"><i class="mdi-huge mdi-progress-download mdi-xl text-primary"></i></div>
              <h3 class="mb-3" style="font-size:1.1rem;">מסיים להתקין…</h3>
            </div>
          `;
        }

        function renderPCSuccessUI(container) {
          container.innerHTML = `
            <div class="text-center" style="max-width:520px;margin:24px auto;padding:0 16px;">
              <div class="mt-4 mb-3"><i class="mdi-huge mdi-check mdi-xl text-success"></i></div>
              <h3 class="text-success font-weight-bold mb-4" style="font-size:1.5rem;">האפליקציה הותקנה בהצלחה</h3>
            </div>
          `;
        }

        function renderSuccessUI(container) {
          container.innerHTML = `
            <div class="text-center" style="max-width:520px;margin:24px auto;padding:0 16px;">
              <div class="mt-4 mb-3"><i class="mdi-huge mdi-check mdi-xl text-success"></i></div>
              <h3 class="text-success font-weight-bold mb-4" style="font-size:1.5rem;">האפליקציה הותקנה בהצלחה</h3>
              <div class="text-center text-primary mb-4">
                <img src="/images/icon-app.webp" class="mt-2" alt="סמל האפליקציה" style="width:60px; height:60px;">
              </div>
              <div class="text-muted mb-4" style="font-size:.95rem;">
                כדי לפתוח את האפליקציה המותקנת<br/>
                חפשו את הסמל החדש במסך הבית או במגירת האפליקציות.
              </div>
              <button id="continue-here-btn" type="button" class="btn btn-primary mb-3">להמשך כאן בדפדפן</button>
            </div>
          `;
        }

        function renderIOSInstallUI(container) {
          container.innerHTML = `
            <div class="modal-body text-center p-4">
              <div class="mb-4">
                <img src="/images/icon-app.webp" alt="סמל האפליקציה" style="width:60px; height:60px;">
              </div>
              <h3 class="modal-title h5 mb-3">התקנת האתר כאפליקציה במכשירך</h3>
              <div class="text-end px-3">
                <ol class="list-unstyled text-center" style="max-width:320px; margin: 0 auto;">
                  <li class="mb-3">לחצו על סמל ה<strong>שיתוף</strong> (ריבוע עם חץ עליון).</li>
                  <li class="mb-3">גללו ובחרו באפשרות "<strong>הוספה למסך הבית</strong>".</li>
                  <li class="mb-2">אשרו את הפעולה בלחיצה על "<strong>הוספה</strong>".</li>
                </ol>
              </div>
              <p class="text-muted mt-4 mb-4" style="font-size: .9rem;">
                שימו לב! באייפון סמל השיתוף נמצא בתחתית המסך, ובאייפד הוא ממוקם בסרגל העליון.
              </p>
              <button id="continue-here-btn" type="button" class="btn btn-primary btn-round">הבנתי, תודה!</button>
            </div>
          `;
        }

        document.addEventListener('click', async (event) => {
          const target = event.target;

          if (target.id === 'continue-here-btn') {
            dismissInstallModal();
            return;
          }

          // This logic now only applies to Android/PC, as iOS users won't see the #install-pwa-btn.
          if (target.id !== 'install-pwa-btn' || installing) return;

          // The iOS check is no longer needed here because it's handled on page load.
          if (!deferredPrompt) {
            return;
          }

          installing = true;
          const mainAppDiv = document.getElementById('main-app');
          deferredPrompt.prompt();
          const { outcome } = await deferredPrompt.userChoice.catch(() => ({ outcome: 'dismissed' }));
          window.setDeferredPrompt(null);

          if (outcome !== 'accepted') {
            installing = false;
            return;
          }

          const installBtn = document.getElementById('our-app');
          if (installBtn) installBtn.style.display = 'none';

          if (!mainAppDiv) {
            installing = false;
            return;
          }

          if (isPC) {
            renderPCSuccessUI(mainAppDiv);
          } else {
            renderInstallingUI(mainAppDiv);
            await new Promise(r => setTimeout(r, 5000));
            renderSuccessUI(mainAppDiv);
          }

          installing = false;
        });

        function hasReloadedForPwaVersion(version) {
          try {
            return sessionStorage.getItem(`mo6:pwa-reloaded:${version}`) === '1';
          } catch {
            return window.__mo6ReloadedForPwaVersion === version;
          }
        }

        function markReloadedForPwaVersion(version) {
          try {
            sessionStorage.setItem(`mo6:pwa-reloaded:${version}`, '1');
          } catch {
            window.__mo6ReloadedForPwaVersion = version;
          }
        }

        function reloadForPwaUpdate(version) {
          if (window.__mo6ReloadingForPwaUpdate || hasReloadedForPwaVersion(version)) return;
          window.__mo6ReloadingForPwaUpdate = true;
          markReloadedForPwaVersion(version);
          window.location.reload();
        }

        function activateWaitingServiceWorker(registration) {
          if (!registration?.waiting) return;
          registration.waiting.postMessage({ type: 'SKIP_WAITING' });
        }

        if ('serviceWorker' in navigator) {
          const pwaAssetVersion = '@pwaAssetVersion';
          const serviceWorkerUrl = `/sw.js?v=${encodeURIComponent(pwaAssetVersion)}`;
          const hadServiceWorkerController = !!navigator.serviceWorker.controller;

          navigator.serviceWorker.addEventListener('controllerchange', () => {
            if (hadServiceWorkerController) {
              reloadForPwaUpdate(pwaAssetVersion);
            }
          });

          window.addEventListener('load', () => {
            navigator.serviceWorker.register(serviceWorkerUrl, { updateViaCache: 'none' })
              .then(async registration => {
                console.log('Service Worker registered with scope:', registration.scope);

                registration.addEventListener('updatefound', () => {
                  const installingWorker = registration.installing;
                  if (!installingWorker) return;

                  installingWorker.addEventListener('statechange', () => {
                    if (installingWorker.state === 'installed' && navigator.serviceWorker.controller) {
                      activateWaitingServiceWorker(registration);
                    }
                  });
                });

                try {
                  await registration.update();
                } catch (error) {
                  console.warn('Service Worker update check failed:', error);
                }

                activateWaitingServiceWorker(registration);
              })
              .catch(error => console.log('Service Worker registration failed:', error));
          });
        }
    </script>


