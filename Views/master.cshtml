    @if (_memberManager.IsLoggedIn())
    {
        @Html.Partial("~/Views/Partials/Logout.cshtml")

        var currentMember = await _memberManager.GetCurrentMemberAsync();
        if (currentMember != null)
        {
            var membership = db.Memberships.GetPreferredMembership(currentMember.Id);
            var expirationDate = membership?.expiration ?? new DateTime(1970, 1, 1);
            var expirationDateOffset = expirationDate.Kind switch
            {
                DateTimeKind.Utc => new DateTimeOffset(expirationDate, TimeSpan.Zero),
                DateTimeKind.Local => new DateTimeOffset(expirationDate),
                _ => new DateTimeOffset(DateTime.SpecifyKind(expirationDate, DateTimeKind.Local))
            };
            var expirationDateISO = expirationDateOffset.ToString("o");
            var expirationUnixMs = expirationDateOffset.ToUnixTimeMilliseconds();
            var expirationDateJson = System.Text.Json.JsonSerializer.Serialize(expirationDateISO);
            var memberIdJson = System.Text.Json.JsonSerializer.Serialize(currentMember.Id);

            <script>
                if (navigator.onLine && typeof offlineContentDB !== 'undefined') {
                    console.log('[Sync] Updating offline membership expiration date.');
                    offlineContentDB.saveMembershipStatus({
                        expiration: @Html.Raw(expirationDateJson),
                        expirationUnixMs: @expirationUnixMs,
                        memberId: @Html.Raw(memberIdJson)
                    })
                        .then(() => console.log('[Sync] Expiration date saved successfully.'))
                        .catch(err => console.error('[Sync] Failed to save expiration date:', err));
                }
            </script>
        }
    }
    else
    {
        @Html.Partial("~/Views/Partials/Login.cshtml")
        @Html.Partial("~/Views/Partials/Register.cshtml")
        @Html.Partial("~/Views/Partials/RegisterAndSubscribe.cshtml", new MO6.ViewModels.RegisterAndSubscribeViewModel { Monthly = true })
