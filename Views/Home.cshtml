@try
{
        @if (_memberManager.IsLoggedIn())
    {
        <script>
            const hash = window.location.hash;

            if (hash === "#register-monthly" || hash === "#register-yearly") {
                window.location.replace('/חשבון');
            }
        </script>
    }
    else
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
            const hash = window.location.hash;

            if (hash === "#register-monthly" || hash === "#register-yearly") {
                // Show modal
                $('#registerSubscribeModal').modal();

                // After modal is fully shown
                $('#registerSubscribeModal').on('shown.bs.modal', function () {
                    if (hash === "#register-monthly") {
                        $('#MonthlySubscription').prop('checked', true).trigger('change');
                    } else if (hash === "#register-yearly") {
                        $('#YearlySubscription').prop('checked', true).trigger('change');
                    }
                });
            }
        });
        </script>
        }
}
catch (Exception e)
{
}


