@inject IMemberManager _memberManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf


@{
    Layout = "master.cshtml";
    var antiforgeryToken = Xsrf.GetAndStoreTokens(Context).RequestToken;

    dynamic HomeCards = Umbraco.Content(3762);
}

<div class="page-header clear-filter" style="background-image: url('@Url.GetCropUrl(Model.Image, "high")');">
    <div class="container">
        <div class="row justify-content-start">
            <div class="col-lg-5">
                <div class="text-center">

                    @if (TempData["verify"] != null)
                    {
                        <div class="card">

                            @if (((bool)TempData["verify"]) == true)
                            {
                                <h2 class="m-4 text-success">האימות התבצע בהצלחה!</h2>


@*                                     <button class="btn btn-success btn-round px-3 py-2 mb-3 mb-sm-0" data-toggle="modal" data-target="#loginModal"><i class="mdi-small mdi-account"></i>לרכישת מנוי</button>
 *@

                            }
                            else
                            {
                                <h2 class="m-4 text-danger">קוד האימות אינו בתוקף</h2>
                            }
                        </div>

                    }
                    else if (TempData["verifyNewEmail"] != null)
                    {
                        <div class="card">

                            @if (((bool)TempData["verifyNewEmail"]) == true)
                            {
                                <h2 class="m-5 text-success">האימות התבצע בהצלחה!</h2>
                            }
                            else
                            {
                                <h2 class="m-5 text-danger">הלינק לאימות אינו בתוקף</h2>
                            }
                        </div>
                    }
                    else if (TempData["PasswordMessage"] != null)
                    {
                        <h2 class="m-5 text-danger">@((string)TempData["PasswordMessage"])</h2>

                    }
                    else if (TempData["email"] != null)
                    {
                        var email = TempData["Email"] as string;
                        var token = TempData["Token"] as string;
                        <div class="card" id="passwordResetForm">
                            <div class="card-body">
                                <form id="resetPasswordForm">
                                    <input type="hidden" id="email" value="@email" />
                                    <input type="hidden" id="token" value="@token" />
                                    <h2 class="primary text-center">איפוס סיסמא</h2>
                                    <div class="form-group  bmd-form-group">
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                <i class="material-icons" aria-hidden="true" lang="en" translate="no">password</i>
                                                </span>
                                            </div>
                                            <label class="bmd-label-floating login-field" for="newPassword">סיסמא חדשה</label>
                                            <input type="password" class="form-control" id="newPassword">
                                        </div>
                                    </div>

                                    <div class="form-group  bmd-form-group">
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="material-icons" aria-hidden="true" lang="en" translate="no">password</i>
                                                </span>
                                            </div>
                                            <label class="bmd-label-floating login-field" for="confirmPassword">אימות סיסמא</label>
                                            <input type="password" class="form-control" id="confirmPassword">
                                            <span id="passwordMismatchError" class="login-error"></span>
                                        </div>
                                    </div>

                                    <button type="submit" class="my-4 btn btn-primary">יצירת סיסמא חדשה</button>
                                </form>
                            </div>
                        </div>

                        <script type="text/javascript">
                            $(document).ready(function () {
                                $("#resetPasswordForm").submit(function (event) {
                                    event.preventDefault();

                                    var email = $("#email").val();
                                    var token = $("#token").val();
                                    var newPassword = $("#newPassword").val();
                                    var confirmPassword = $("#confirmPassword").val();

                                    // Clear previous error
                                    $("#passwordMismatchError").text('');

                                    // Check if passwords match
                                    if (newPassword !== confirmPassword) {
                                        $("#passwordMismatchError").text("הסיסמאות אינן תואמות.");
                                        return;
                                    }

                                    $.ajax({
                                        url: '@Url.SurfaceAction("ResetPassword","CustomLogin")',
                                        type: 'POST',
                                        data: {
                                            __RequestVerificationToken: '@antiforgeryToken',
                                            email: email,
                                            token: token,
                                            newPassword: newPassword
                                        },
                                        success: function (response) {
                                            $("#passwordResetForm").html('<h2 class="text-success">' + response.message + '</h2>');
                                        },
                                        error: function (xhr) {
                                            $("#passwordResetForm").html('<h2 class="text-danger">' + xhr.responseJSON.message + '</h2>');
                                        }
                                    });
                                });
                            });
                        </script>
                    }
                    else
                    {
                        <h1>@Model.Title</h1>
                        @if (Model.Subtitle != null)
                        {
                            <h2>@Model.Subtitle</h2>
                        }
                        @if (Model.SubSubtitle != null)
                        {
                            <h3>@Model.SubSubtitle</h3>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="row justify-content-start">
            <div class="col-lg-5 text-center">
                <div>
                    @if (_memberManager.IsLoggedIn())
                    {
                        var member = await _memberManager.GetCurrentMemberAsync();
                        if(member!=null)
                        {
                        <h3>שלום @member.Name !</h3>
                        <a href="/חשבון" class="btn btn-success btn-round btn-home p-2"><i class="mdi mdi-account" aria-hidden="true"></i> לחשבון</a>
                        }
                    }
                    else
                    {
                        <button class="btn btn-primary btn-round btn-home p-2" style="line-height: 1.4;" data-toggle="modal" data-target="#loginModal"><i class="mdi mdi-login-variant" aria-hidden="true"></i> התחברות</button>
                        <button class="btn btn-success btn-round btn-home p-2" style="line-height: 1.4;" data-toggle="modal" data-target="#registerModal"><i class="mdi mdi-pencil-box-outline" aria-hidden="true"></i> הרשמה</button>
                    }

                    <button id="our-app" class="btn btn-round btn-home p-2 mt-3" data-toggle="modal" data-target="#appInstallModal" style="display:none;width:210px;background-color:rgb(0 0 0 / 40%);line-height: 1.4;">
                                                                <i class="mdi mdi-monitor-cellphone" aria-hidden="true"></i> 
                     האפליקציה שלנו<div class="ripple-container"></div></button>
                </div>
            </div>
        </div>
    </div>
</div>

@try
{
    <div class="container">

        <div class="row justify-content-center">
            @foreach (dynamic CardOrTitle in HomeCards.CardsList)
            {
                if (CardOrTitle is HomeTitle title)
                {
                    @:         </div>
                    <h1 class="text-center text-primary">@title.Title</h1>
                    @:          <div class="row justify-content-center">
                }
                else if (CardOrTitle is HomeCard card)
                {
                    bool hasLink = !string.IsNullOrEmpty(card.CardLink);
                    string subtitle = Convert.ToString(card.Subtitle);
                    <div class="col-md-4">
                        <div class="rounded mt-4 px-3 pt-3" style="background-color:white;height:95%;">
                            <div class="card card-plain mt-0">
                                @if (hasLink)
                                {
                                    <a href="@card.CardLink">
                                        <img class="rounded" style="width:100%;" src="@Url.GetCropUrl(card.Image, "small")" alt="@card.ImageAlt">
                                    </a>
                                }
                                else
                                {
                                    <img class="rounded" style="width:100%;" src="@Url.GetCropUrl(card.Image, "small")" alt="@card.ImageAlt">
                                }
                                <div class="card-body text-center">
                                    @if (!string.IsNullOrWhiteSpace(subtitle))
                                    {
                                        if (hasLink)
                                        {
                                            <a href="@card.CardLink">
                                                <h6 class="mt-0 card-category">@subtitle</h6>
                                            </a>
                                        }
                                        else
                                        {
                                            <h6 class="mt-0 card-category">@subtitle</h6>
                                        }
                                    }
                                    @if (hasLink)
                                    {
                                        <a href="@card.CardLink">
                                            <h4 class="card-title" style="margin-bottom:.625rem;">@card.Title</h4>
                                        </a>
                                        <a href="@card.CardLink">
                                            <p class="card-description">
                                                @card.Content
                                            </p>
                                        </a>
                                    }
                                    else
                                    {
                                        <h4 class="card-title" style="margin-bottom:.625rem;">@card.Title</h4>
                                        <p class="card-description">
                                            @card.Content
                                        </p>
                                    }
                                                            <div class="mt-4">

                                        @if(!string.IsNullOrEmpty(card.Button1))
                                        {
                                            var link1 = card.Button1Link != null ? (card.Button1Link.Url, card.Button1Link.Target) : ("","");
                                            <a href="@link1.Item1" target="@link1.Item2" class="btn btn-primary btn-round px-3 py-2"> @card.Button1</a>
                                        }
                                        @if(!string.IsNullOrEmpty(card.Button2))
                                        {
                                            var link2 = card.Button2Link != null ? (card.Button2Link.Url, card.Button2Link.Target) : ("","");
                                            <a href="@link2.Item1" target="@link2.Item2" class="btn btn-primary btn-round px-3 py-2"> @card.Button2</a>
                                        }
                                        @if(!string.IsNullOrEmpty(card.Button3))
                                        {
                                            var link3 = card.Button3Link != null ? (card.Button3Link.Url, card.Button3Link.Target) : ("","");
                                            <a href="@link3.Item1" target="@link3.Item2" class="btn btn-primary btn-round px-3 py-2"> @card.Button3</a>
                                        }
                                        </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }   
        </div>
    </div>

    <!-- Place this in a prominent location on your Home Page -->
}
catch
{
    
}

