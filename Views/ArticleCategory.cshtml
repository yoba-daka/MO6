@using Umbraco.Cms.Core.PropertyEditors.ValueConverters;
@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;

@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ArticleCategory>
@{
    Layout = "master.cshtml";
    dynamic parent = Model.Parent;
}

@functions {
    void RenderItem(dynamic item)
    {
        if (item is Article article)
        {
            <div class="col-lg-3 col-md-4 col-6 pl-0 " style="overflow:hidden">
                                            @if (article.New)
                                {
                                    <div class="new">
                                        <div class="new-text">חדש</div>
                                    </div>
                                }
                <a href="@article.Url()">
                    <img src="@Url.GetCropUrl(article.Image, "small")" alt="@article.ImageAlt" class="rounded img-fluid" loading="lazy" decoding="async">
                    <h5 style="line-height: 22px;" class="title m-2">@article.Title</h5>
                </a>
            </div>
        }
        else if (item is ArticleCategory category)
        {
            <div class="col-lg-3 col-md-4 col-6 pl-0 ">
                <a href="@category.Url()">

                  <div class="image-container" style=" position: relative; display: flex; align-items: center; justify-content: center;">
                                                  <span class="badge badge-pill badge-primary time">@(category.Children.Count()) מקבצים / מאמרים</span>

                    <i class="material-icons list" aria-hidden="true" lang="en" translate="no">list</i>

                    <img src="@Url.GetCropUrl(category.Image, "small")" alt="@category.ImageAlt" class="rounded img-fluid" loading="lazy" decoding="async">
            </div>
                                <h5 style="line-height: 22px;" class="title m-2">@category.Title</h5>

                            </a>

            </div>
        }
    }
    Tuple<string, int> GenerateBreadcrumb(dynamic currentItem)
    {
        if (currentItem == null) return new Tuple<string, int>(string.Empty, 0);

        // Assuming IPublishedContent has a Url property, but we might need to cast to access it
        string url = (currentItem as IPublishedContent).Url();
        string name = currentItem.Name;

        if (currentItem.Parent != null && currentItem.Parent.Parent != null)
        {
            // Recursion to get the parent breadcrumb trail
            var parentBreadcrumb = GenerateBreadcrumb(currentItem.Parent);
            int position = parentBreadcrumb.Item2 + 1;
            string breadcrumbItem = $"<span itemprop='itemListElement' itemscope itemtype='https://schema.org/ListItem'><a class='title text-primary' itemprop='item' href='{url}'><span itemprop='name'>{name}</span></a><meta itemprop='position' content='{position}' /></span>";
            return new Tuple<string, int>($"{parentBreadcrumb.Item1} &nbsp>&nbsp {breadcrumbItem}", position);
        }
        else
        {
            // Base case: the item directly beneath the root (no grandparent)
            int position = 1;
            string breadcrumbItem = $"<span itemprop='itemListElement' itemscope itemtype='https://schema.org/ListItem'><a class='title text-primary' itemprop='item' href='{url}'><span itemprop='name'>{name}</span></a><meta itemprop='position' content='{position}' /></span>";
            return new Tuple<string, int>(breadcrumbItem, position);
        }
    }
}

<div class="sec-page-header page-header header-filter clear-filter" style="margin-top:0em;background-image: url('@Url.GetCropUrl(((Articles)Model.AncestorOrSelf("Articles")).Image, "full")');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="text-center">
                    <h1>@Model.Title</h1>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container pt-0">
    <div class="my-5">
        @{
            var breadcrumbData = GenerateBreadcrumb(parent);
            int currentPosition = breadcrumbData.Item2 + 1;
        }

        @Html.Raw(breadcrumbData.Item1)
        &nbsp>&nbsp
        <span itemprop='itemListElement' itemscope itemtype='https://schema.org/ListItem'>
            <a class="title text-primary" itemprop="item" href="@Model.Url()">
                <span itemprop="name">@Model.Name</span>
            </a>
            <meta itemprop="position" content="@currentPosition" />
        </span>
    </div>
    @if (Model.ArticleList != null)
    {
        <div class="row  pl-3" style="text-align:center;">
            @foreach (var item in Model.ArticleList)
            {
                RenderItem(item);
            }
        </div>
    }
</div>

